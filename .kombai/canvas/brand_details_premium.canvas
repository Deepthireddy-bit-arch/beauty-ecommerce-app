placeholder=\"ENTER EMAIL ARCHIVE\" class=\"flex-1 bg-transparent p-4 text-[10px] font-bold uppercase tracking-widest outline-none\" data-kid=\"218\">\n            <button class=\"bg-black text-white px-8 font-syne font-black text-xs uppercase hover:bg-[#FF4500] hover:text-black transition-colors\" data-kid=\"219\">Join</button>\n          </div>\n        </div>\n        <p class=\"text-[9px] font-bold uppercase tracking-widest opacity-40 mt-12\" data-kid=\"220\">\n          &copy; 2026 LUMOS EDITION GLOBAL COLLECTIVE. ALL RIGHTS RESERVED. BEYOND THE SURFACE.\n        </p>\n      </div>\n    </div>\n  </footer>\n\n</div>\n",
