      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    background-color: #FAF9F6;\n    color: #2C352D;\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n  }\n\n  .font-serif {\n    font-family: 'Playfair Display', serif;\n  }\n\n  .text-deep-moss { color: #2C352D; }\n  .bg-deep-moss { background-color: #2C352D; }\n  .text-sage-green { color: #5F7063; } /* Darkened for better readability on Alabaster */\n  .bg-sage-green { background-color: #7C9082; }\n  .border-soft-ash { border-color: #E3E5E1; }\n\n  /* Smooth reveal for quick add */\n  .quick-add-btn {\n    transform: translateY(100%);\n    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n  .product-card:hover .quick-add-btn {\n    transform: translateY(0);\n  }\n\n  /* Custom Pill Tab Shadow */\n  .tab-bar-shadow {\n    box-shadow: 0 20px 50px -15px rgba(44, 53, 45, 0.08);\n  }\n\n  /* Silk Banner Effect */\n  .silk-overlay {\n    mix-blend-mode: multiply;\n    opacity: 0.15;\n  }\n</style>\n\n<div class=\"bg-[#FAF9F6] selection:bg-[#7C9082]/30\" data-kid=\"1\">\n\n  \n  <header class=\"relative w-full h-[700px] flex overflow-hidden\" data-kid=\"2\">\n    \n    <div class=\"w-[40%] bg-white flex flex-col justify-center px-20 relative z-10 border-r border-[#E3E5E1]\" data-kid=\"3\">\n      <button class=\"absolute top-10 left-20 flex items-center gap-2 text-[10px] font-bold tracking-[0.2em] text-[#7C9082] hover:text-[#2C352D] transition-colors group\" data-kid=\"4\">\n        <i class=\"ti ti-arrow-left transition-transform group-hover:-translate-x-1\" data-kid=\"5\"></i>\n        BACK TO BRANDS\n      </button>\n\n      <div class=\"space-y-8\" data-kid=\"6\">\n        \n        <div class=\"relative w-28 h-28 group\" data-kid=\"7\">\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/circle.svg\" class=\"absolute inset-0 w-full h-full opacity-10 group-hover:rotate-180 transition-transform duration-[3s] linear\" style=\"filter: invert(18%) sepia(13%) saturate(542%) hue-rotate(84deg) brightness(95%) contrast(89%);\" data-kid=\"8\">\n          <div class=\"absolute inset-0 flex items-center justify-center font-serif text-5xl font-bold text-[#2C352D]\" data-kid=\"9\">A</div>\n        </div>\n\n        <div data-kid=\"10\">\n          <div class=\"flex items-center gap-3 mb-3\" data-kid=\"11\">\n             <span class=\"text-[10px] uppercase tracking-[0.25em] text-[#7C9082] font-bold\" data-kid=\"12\">Pure Botanical Science</span>\n             <span class=\"w-1.5 h-1.5 rounded-full bg-[#E3E5E1]\" data-kid=\"13\"></span>\n             <span class=\"text-[10px] uppercase tracking-[0.25em] text-[#7C9082] font-bold\" data-kid=\"14\">Provence, France</span>\n          </div>\n          <h1 class=\"font-serif text-7xl font-bold leading-[0.9] tracking-tight mb-6\" data-kid=\"15\">Aura<br data-kid=\"16\">Botanica</h1>\n          <p class=\"font-serif italic text-xl text-[#2C352D]/60 max-w-sm leading-relaxed\" data-kid=\"17\">\n            \"We believe in the quiet power of nature, refined by the precision of time.\"\n          </p>\n        </div>\n\n        <div class=\"flex gap-16 pt-4\" data-kid=\"18\">\n          <div class=\"flex flex-col\" data-kid=\"19\">\n            <span class=\"font-serif text-4xl font-bold text-[#2C352D]\" data-kid=\"20\">4.9<span class=\"text-xl ml-1\" data-kid=\"21\">★</span></span>\n            <span class=\"text-[9px] uppercase tracking-[0.2em] text-[#7C9082] font-bold mt-1\" data-kid=\"22\">Heritage Rating</span>\n          </div>\n          <div class=\"flex flex-col\" data-kid=\"23\">\n            <span class=\"font-serif text-4xl font-bold text-[#2C352D]\" data-kid=\"24\">124</span>\n            <span class=\"text-[9px] uppercase tracking-[0.2em] text-[#7C9082] font-bold mt-1\" data-kid=\"25\">Curated Items</span>\n          </div>\n        </div>\n\n        <div class=\"flex flex-wrap gap-2.5 pt-4\" data-kid=\"26\">\n          <span class=\"px-5 py-2 rounded-full border border-[#E3E5E1] text-[10px] font-bold text-[#7C9082] hover:bg-[#FAF9F6] transition-colors cursor-default\" data-kid=\"27\">🐰 CRUELTY-FREE</span>\n          <span class=\"px-5 py-2 rounded-full border border-[#E3E5E1] text-[10px] font-bold text-[#7C9082] hover:bg-[#FAF9F6] transition-colors cursor-default\" data-kid=\"28\">🌍 SUSTAINABLE</span>\n          <span class=\"px-5 py-2 rounded-full border border-[#E3E5E1] text-[10px] font-bold text-[#7C9082] hover:bg-[#FAF9F6] transition-colors cursor-default\" data-kid=\"29\">🌿 VEGAN</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"w-[60%] relative h-full\" data-kid=\"30\">\n      <img src=\"https://images.unsplash.com/photo-1587499211757-86eeee9c75da?auto=format&w=1600&q=85&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Pristine dew drops on leaf\" decoding=\"async\" loading=\"lazy\" data-kid=\"31\">\n      <div class=\"absolute inset-0 bg-gradient-to-r from-white via-white/10 to-transparent w-1/4\" data-kid=\"32\"></div>\n      \n      \n      <div class=\"absolute bottom-12 right-12 text-white/50 text-[10px] tracking-[0.3em] font-medium uppercase rotate-90 origin-right\" data-kid=\"33\">\n        Collection 01 — Primordial Essence\n      </div>\n    </div>\n    \n    \n    <div class=\"absolute -bottom-10 left-1/2 -translate-x-1/2 z-30 flex justify-center w-full max-w-4xl px-4\" data-kid=\"34\">\n      <div class=\"bg-white/95 backdrop-blur-md rounded-full tab-bar-shadow border border-[#E3E5E1] p-2 flex items-center gap-2 w-full justify-between ring-1 ring-black/[0.03]\" data-kid=\"35\">\n        <div class=\"flex gap-1\" data-kid=\"36\">\n          <button class=\"px-10 py-3.5 rounded-full bg-[#7C9082] text-white text-[10px] font-bold tracking-widest transition-all shadow-lg shadow-[#7C9082]/20\" data-kid=\"37\">ALL PRODUCTS</button>\n          <button class=\"px-10 py-3.5 rounded-full hover:bg-[#FAF9F6] text-[#2C352D]/70 hover:text-[#2C352D] text-[10px] font-bold tracking-widest transition-all\" data-kid=\"38\">SKINCARE</button>\n          <button class=\"px-8 py-3 rounded-full hover:bg-[#FAF9F6] text-[#2C352D]/70 hover:text-[#2C352D] text-[10px] font-bold tracking-widest transition-all\" data-kid=\"39\">MAKEUP</button>\n          <button class=\"px-8 py-3 rounded-full hover:bg-[#FAF9F6] text-[#2C352D]/70 hover:text-[#2C352D] text-[10px] font-bold tracking-widest transition-all\" data-kid=\"40\">HAIRCARE</button>\n        </div>\n        <div class=\"flex items-center gap-6 pr-8 border-l border-[#E3E5E1] pl-8\" data-kid=\"41\">\n           <span class=\"text-[10px] uppercase font-bold text-[#7C9082] tracking-[0.2em] cursor-default\" data-kid=\"42\">REFINE</span>\n           <button class=\"text-[#2C352D] transition-transform hover:rotate-180 duration-500\" data-kid=\"43\">\n             <i class=\"ti ti-sliders text-xl\" data-kid=\"44\"></i>\n           </button>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  \n  <section class=\"mt-32 mb-32 px-20\" data-kid=\"45\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"46\">\n      <div class=\"grid grid-cols-12 gap-20 items-start\" data-kid=\"47\">\n        \n        <div class=\"col-span-5 space-y-12\" data-kid=\"48\">\n           <h2 class=\"font-serif text-5xl font-bold text-[#2C352D] tracking-tight\" data-kid=\"49\">Our Philosophy</h2>\n           <div class=\"relative\" data-kid=\"50\">\n             <div class=\"aspect-[4/5] rounded-[2rem] overflow-hidden shadow-2xl border-4 border-white\" data-kid=\"51\">\n               <img src=\"https://images.unsplash.com/photo-1653750660402-d009795394b2?auto=format&w=1000&q=80&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Botanical texture\" decoding=\"async\" loading=\"lazy\" data-kid=\"52\">\n             </div>\n             \n             <div class=\"absolute -bottom-8 -right-8 w-48 h-48 bg-white p-4 rounded-3xl shadow-2xl transform hover:-translate-y-4 transition-transform duration-500 ring-1 ring-black/[0.03]\" data-kid=\"53\">\n               <img src=\"https://images.unsplash.com/photo-1573869874806-8121ff9a7939?auto=format&w=400&q=80&fit=crop\" class=\"w-full h-full object-cover rounded-2xl\" alt=\"Secondary texture\" decoding=\"async\" loading=\"lazy\" data-kid=\"54\">\n             </div>\n           </div>\n        </div>\n\n        \n        <div class=\"col-span-7 pt-24 space-y-10\" data-kid=\"55\">\n           <div class=\"w-full h-px bg-[#E3E5E1]\" data-kid=\"56\"></div>\n           <blockquote class=\"font-serif italic text-3xl text-[#2C352D] leading-[1.4] tracking-tight\" data-kid=\"57\">\n             \"We do not merely create beauty products; we preserve the ephemeral essence of the botanical world in every drop.\"\n           </blockquote>\n           <div class=\"grid grid-cols-2 gap-12 text-[#2C352D]/70 leading-relaxed text-sm font-light\" data-kid=\"58\">\n             <p data-kid=\"59\">\n               Every formulation begins in our gardens in Provence, where we cultivate rare botanicals with ancient techniques. Our scientists then spend years refining these extracts to unlock their highest potential, ensuring that your skin receives only the most potent, purest nutrients.\n             </p>\n             <p data-kid=\"60\">\n               Aura Botanica stands at the intersection of tradition and innovation. We are committed to a 100% transparent supply chain, biodegradable packaging, and clinical excellence. True luxury is not loud; it is the quiet confidence of knowing you are caring for yourself and the planet simultaneously.\n             </p>\n           </div>\n           <div class=\"w-full h-px bg-[#E3E5E1]\" data-kid=\"61\"></div>\n           \n           \n           <div class=\"flex items-center gap-16 pt-6\" data-kid=\"62\">\n             <div class=\"flex flex-col items-center gap-4 group\" data-kid=\"63\">\n               <div class=\"w-16 h-16 rounded-full bg-white flex items-center justify-center border border-[#E3E5E1] transition-all group-hover:bg-[#7C9082] group-hover:border-[#7C9082]\" data-kid=\"64\">\n                 <i class=\"ti ti-leaf text-2xl text-[#7C9082] group-hover:text-white transition-colors\" data-kid=\"65\"></i>\n               </div>\n               <span class=\"text-[10px] uppercase tracking-[0.3em] font-bold text-[#7C9082]\" data-kid=\"66\">CLEAN INGREDIENTS</span>\n             </div>\n             <div class=\"flex flex-col items-center gap-4 group\" data-kid=\"67\">\n               <div class=\"w-16 h-16 rounded-full bg-white flex items-center justify-center border border-[#E3E5E1] transition-all group-hover:bg-[#7C9082] group-hover:border-[#7C9082]\" data-kid=\"68\">\n                 <i class=\"ti ti-microscope text-2xl text-[#7C9082] group-hover:text-white transition-colors\" data-kid=\"69\"></i>\n               </div>\n               <span class=\"text-[10px] uppercase tracking-[0.3em] font-bold text-[#7C9082]\" data-kid=\"70\">CLINICALLY TESTED</span>\n             </div>\n             <div class=\"flex flex-col items-center gap-4 group\" data-kid=\"71\">\n               <div class=\"w-16 h-16 rounded-full bg-white flex items-center justify-center border border-[#E3E5E1] transition-all group-hover:bg-[#7C9082] group-hover:border-[#7C9082]\" data-kid=\"72\">\n                 <i class=\"ti ti-droplets text-2xl text-[#7C9082] group-hover:text-white transition-colors\" data-kid=\"73\"></i>\n               </div>\n               <span class=\"text-[10px] uppercase tracking-[0.3em] font-bold text-[#7C9082]\" data-kid=\"74\">SUSTAINABLE Purity</span>\n             </div>\n           </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"px-20 mb-32\" data-kid=\"75\">\n    <div class=\"max-w-7xl mx-auto relative round