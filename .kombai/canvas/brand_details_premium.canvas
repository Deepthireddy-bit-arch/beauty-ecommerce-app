      "html": "\n<div class=\"bg-white text-[#1A0B2E] font-['Montserrat']\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@200;300;400;500;600;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .font-serif { font-family: 'Playfair Display', serif; }\n        .font-sans { font-family: 'Montserrat', sans-serif; }\n\n        /* Custom underline replacement with star */\n        .tab-active::before {\n            content: '★';\n            position: absolute;\n            top: -16px;\n            left: 50%;\n            transform: translateX(-50%);\n            color: #9D4EDD;\n            font-size: 11px;\n            filter: drop-shadow(0 0 5px rgba(157, 78, 221, 0.4));\n        }\n\n        /* Hover scale effect */\n        .card-image-container:hover .quick-add-btn {\n            opacity: 1;\n            transform: translateY(0);\n        }\n        \n        /* Drop shadow for overlap effect */\n        .hero-shadow {\n            box-shadow: 40px 40px 80px rgba(26, 11, 46, 0.08);\n        }\n    </style>\n\n    \n    <nav class=\"px-12 py-8 flex justify-between items-center border-b border-[#F3E8FF] bg-white z-[100]\" data-kid=\"2\">\n        <div class=\"text-[10px] tracking-[0.4em] uppercase font-bold opacity-60\" data-kid=\"3\">Collection / 2024</div>\n        <div class=\"text-xl font-serif tracking-widest font-bold\" data-kid=\"4\">REFULGENT LUXURY</div>\n        <div class=\"flex gap-8 text-[10px] tracking-widest uppercase font-bold\" data-kid=\"5\">\n            <a href=\"#\" class=\"opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"6\">Archive</a>\n            <a href=\"#\" class=\"opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"7\">Sustainability</a>\n            <a href=\"#\" class=\"text-[#9D4EDD]\" data-kid=\"8\">Shop</a>\n        </div>\n    </nav>\n\n    \n    <section class=\"relative h-[850px] flex items-center overflow-hidden\" data-kid=\"9\">\n        \n        <div class=\"absolute -top-40 -left-40 w-[600px] h-[600px] bg-[#9D4EDD]/10 rounded-full blur-[140px] pointer-events-none\" data-kid=\"10\"></div>\n        \n        <div class=\"container mx-auto px-12 h-full flex items-center\" data-kid=\"11\">\n            \n            <div class=\"w-1/2 relative pr-20\" data-kid=\"12\">\n                <div class=\"absolute left-[-20px] top-1/2 -translate-y-1/2 h-[70%] w-px bg-[#1A0B2E]/10\" data-kid=\"13\"></div>\n                <div class=\"mb-12\" data-kid=\"14\">\n                    <span class=\"text-xs tracking-[0.5em] font-bold opacity-60 uppercase\" data-kid=\"15\">01 / BRAND IDENTITY</span>\n                </div>\n                \n                <div class=\"mb-14 w-28 h-28 rounded-full border border-[#1A0B2E]/10 flex items-center justify-center p-6 bg-[#FAFAFF]/50 backdrop-blur-xs\" data-kid=\"16\">\n                    <img src=\"https://images.unsplash.com/photo-1582103540024-f12c99ace136?auto=format&w=200&q=80\" alt=\"Brand Logo\" class=\"w-full h-full object-contain mix-blend-multiply opacity-80\" data-kid=\"17\">\n                </div>\n\n                <h1 class=\"font-serif text-[100px] leading-[1] mb-10 tracking-tight\" data-kid=\"18\">Refulgent<br data-kid=\"19\">Essence</h1>\n                <p class=\"text-xl font-light leading-relaxed max-w-lg opacity-70 mb-12\" data-kid=\"20\">\n                    Where molecular science meets the ethereal beauty of botanical extracts. A refulgent journey into the heart of luxury skincare.\n                </p>\n\n                <div class=\"flex gap-12 items-center\" data-kid=\"21\">\n                    <div class=\"flex flex-col\" data-kid=\"22\">\n                        <span class=\"text-[9px] tracking-[0.3em] uppercase font-bold opacity-30 mb-1\" data-kid=\"23\">Origin</span>\n                        <span class=\"text-sm font-semibold\" data-kid=\"24\">Paris, FR</span>\n                    </div>\n                    <div class=\"flex flex-col\" data-kid=\"25\">\n                        <span class=\"text-[9px] tracking-[0.3em] uppercase font-bold opacity-30 mb-1\" data-kid=\"26\">Founded</span>\n                        <span class=\"text-sm font-semibold\" data-kid=\"27\">Est. 2012</span>\n                    </div>\n                    <div class=\"flex flex-col\" data-kid=\"28\">\n                        <span class=\"text-[9px] tracking-[0.3em] uppercase font-bold opacity-30 mb-1\" data-kid=\"29\">Status</span>\n                        <span class=\"text-sm font-semibold\" data-kid=\"30\">Cruelty-Free</span>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"w-1/2 h-full flex items-center justify-center relative\" data-kid=\"31\">\n                \n                <div class=\"absolute left-0 top-1/2 -translate-y-1/2 h-1/2 w-px bg-[#1A0B2E]/10\" data-kid=\"32\"></div>\n                \n                <div class=\"relative w-[520px] h-[740px] z-10 hero-shadow group\" data-kid=\"33\">\n                    <img src=\"https://images.unsplash.com/photo-1582103645388-b85304592cb0?auto=format&w=1000&q=90&fit=crop\" alt=\"Luxurious Skincare Flatlay\" class=\"w-full h-full object-cover grayscale-[0.1] group-hover:grayscale-0 transition-all duration-1000\" decoding=\"async\" loading=\"lazy\" data-kid=\"34\">\n                    \n                    <div class=\"absolute -bottom-12 -left-12 w-80 h-80 bg-[#F3E8FF] -z-10 blur-xl opacity-40\" data-kid=\"35\"></div>\n                </div>\n\n                <div class=\"absolute right-[-40px] top-1/2 -translate-y-1/2 rotate-90 origin-right text-[10px] tracking-[1.5em] uppercase opacity-20 whitespace-nowrap font-bold\" data-kid=\"36\">\n                    RADIANCE UNVEILED • SKINCARE COLLECTIVE\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <div class=\"bg-white py-10 border-y border-[#F3E8FF] z-50\" data-kid=\"37\">\n        <nav class=\"flex justify-center items-center space-x-16\" data-kid=\"38\">\n            <a href=\"#\" class=\"relative text-[11px] tracking-[0.4em] uppercase font-bold text-[#1A0B2E] tab-active\" data-kid=\"39\">All Products</a>\n            <a href=\"#\" class=\"text-[11px] tracking-[0.4em] uppercase font-bold opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"40\">Skincare</a>\n            <a href=\"#\" class=\"text-[11px] tracking-[0.4em] uppercase font-bold opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"41\">Makeup</a>\n            <a href=\"#\" class=\"text-[11px] tracking-[0.4em] uppercase font-bold opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"42\">Haircare</a>\n            <a href=\"#\" class=\"text-[11px] tracking-[0.4em] uppercase font-bold opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"43\">Fragrance</a>\n        </nav>\n    </div>\n\n    \n    <section class=\"py-32 px-12 bg-white\" data-kid=\"44\">\n        <div class=\"container mx-auto max-w-6xl text-center\" data-kid=\"45\">\n            <h2 class=\"font-serif italic text-6xl leading-tight mb-20 text-[#1A0B2E] max-w-4xl mx-auto\" data-kid=\"46\">\n                \"Radiance is not just a visual attribute, but a molecular state of harmony between nature and science.\"\n            </h2>\n            \n            <div class=\"grid grid-cols-2 gap-24 text-left relative px-12\" data-kid=\"47\">\n                \n                <div class=\"absolute left-1/2 top-0 -translate-x-1/2 h-full flex flex-col items-center\" data-kid=\"48\">\n                    <div class=\"w-px h-1/4 bg-[#F3E8FF]\" data-kid=\"49\"></div>\n                    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/fragrance.svg\" class=\"w-16 h-16 my-10 opacity-30\" style=\"filter: invert(41%) sepia(85%) saturate(1904%) hue-rotate(248deg) brightness(89%) contrast(92%);\" data-kid=\"50\">\n                    <div class=\"w-px h-1/4 bg-[#F3E8FF]\" data-kid=\"51\"></div>\n                </div>\n\n                <div data-kid=\"52\">\n                    <p class=\"text-xl font-light leading-[1.9] opacity-90\" data-kid=\"53\">\n                        <span class=\"text-8xl font-serif mr-5 float-left text-[#9D4EDD] leading-[0.7] mt-3\" data-kid=\"54\">R</span>\n                        efulgent Essence was born in a small apothecary in the heart of Paris, driven by a singular vision: to create skincare that radiates from the deepest layers of the epidermis. Our founders believed that luxury shouldn't come at the cost of clinical integrity.\n                    </p>\n                </div>\n                <div data-kid=\"55\">\n                    <p class=\"text-xl font-light leading-[1.8] opacity-70\" data-kid=\"56\">\n                        Today, our laboratories continue this legacy, blending rare botanicals with patented molecular delivery systems. We are committed to refulgent luxury — a standard of beauty that is as sustainable as it is sophisticated, ensuring a glowing future for both your skin and the planet.\n                    </p>\n                    <div class=\"mt-12 flex gap-10\" data-kid=\"57\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"58\">\n                            <span class=\"text-2xl\" data-kid=\"59\">🌿</span>\n                            <span class=\"text-[10px] tracking-widest uppercase font-bold opacity-50\" data-kid=\"60\">Clean Ingredients</span>\n                        </div>\n                        <div class=\"flex items-center gap-3\" data-kid=\"61\">\n                            <span class=\"text-2xl\" data-kid=\"62\">🔬</span>\n                            <span class=\"text-[10px] tracking-widest uppercase font-bold opacity-50\" data-kid=\"63\">Clinically Proven</span>\n                        </div>\n                    </div>\n         