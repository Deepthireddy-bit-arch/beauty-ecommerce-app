      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: #FFFFFF;\n    color: #000000;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n  }\n\n  .font-syne {\n    font-family: 'Syne', sans-serif;\n  }\n\n  .no-scrollbar::-webkit-scrollbar {\n    display: none;\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .animate-marquee {\n    display: flex;\n    width: fit-content;\n    animation: marquee 30s linear infinite;\n  }\n\n  .grid-spreadsheet {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    border-top: 2px solid #000000;\n    border-left: 2px solid #000000;\n  }\n\n  .grid-spreadsheet > div {\n    border-right: 2px solid #000000;\n    border-bottom: 2px solid #000000;\n  }\n\n  @media (max-width: 1024px) {\n    .grid-spreadsheet {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media (max-width: 640px) {\n    .grid-spreadsheet {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n\n<div class=\"min-h-screen bg-white text-black selection:bg-[#FF4500] selection:text-black\" data-kid=\"1\">\n  \n  \n  <header class=\"border-b-2 border-black overflow-hidden\" data-kid=\"2\">\n    <div class=\"grid grid-cols-12\" data-kid=\"3\">\n      \n      <div class=\"col-span-12 lg:col-span-7 border-r-0 lg:border-r-2 border-black p-8 lg:p-16 flex flex-col justify-between h-auto lg:h-[800px] relative\" data-kid=\"4\">\n        <div class=\"z-20\" data-kid=\"5\">\n          <div class=\"flex items-center gap-6 mb-12\" data-kid=\"6\">\n            <div class=\"w-20 h-20 border-2 border-black flex items-center justify-center font-['Syne'] font-black text-4xl bg-white\" data-kid=\"7\">L</div>\n            <div class=\"space-y-1\" data-kid=\"8\">\n              <p class=\"text-xs tracking-[0.2em] uppercase font-bold opacity-40\" data-kid=\"9\">Luxury Skin-Conscious Artistry</p>\n              <div class=\"flex gap-2\" data-kid=\"10\">\n                <span class=\"bg-[#FF4500] text-black px-2 py-0.5 text-[10px] font-bold uppercase border border-black\" data-kid=\"11\">Est. 2012</span>\n                <span class=\"bg-black text-white px-2 py-0.5 text-[10px] font-bold uppercase border border-black\" data-kid=\"12\">Cruelty-Free</span>\n              </div>\n            </div>\n          </div>\n          \n          <h1 class=\"font-syne text-[8rem] sm:text-[10rem] lg:text-[14rem] font-extrabold leading-[0.75] tracking-tighter uppercase mb-4 select-none break-all sm:break-normal\" data-kid=\"13\">\n            LUMOS<br data-kid=\"14\">\n            <span class=\"text-[#FF4500] mix-blend-multiply\" data-kid=\"15\">EDITION</span>\n          </h1>\n        </div>\n\n        <div class=\"flex flex-col sm:flex-row justify-between items-start sm:items-end gap-8 z-20 mt-12\" data-kid=\"16\">\n          <div class=\"space-y-6 max-w-md\" data-kid=\"17\">\n            <p class=\"text-sm lg:text-base uppercase leading-relaxed font-bold tracking-tight\" data-kid=\"18\">\n              Redefining the boundaries of skin-conscious artistry through avant-garde formulations and brutalist aesthetics. Designed for the discerning individual.\n            </p>\n            <div class=\"flex gap-16\" data-kid=\"19\">\n              <div data-kid=\"20\">\n                <p class=\"font-syne text-5xl font-extrabold italic\" data-kid=\"21\">4.9★</p>\n                <p class=\"text-[10px] uppercase font-bold tracking-widest opacity-40 mt-1\" data-kid=\"22\">Global Rating</p>\n              </div>\n              <div data-kid=\"23\">\n                <p class=\"font-syne text-5xl font-extrabold italic\" data-kid=\"24\">128+</p>\n                <p class=\"text-[10px] uppercase font-bold tracking-widest opacity-40 mt-1\" data-kid=\"25\">Curated Items</p>\n              </div>\n            </div>\n          </div>\n          <button class=\"w-20 h-20 border-2 border-black rounded-full flex items-center justify-center hover:bg-black hover:text-white transition-all duration-300 group\" data-kid=\"26\">\n            <i class=\"ti ti-arrow-down-right text-3xl group-hover:translate-x-1 group-hover:translate-y-1 transition-transform\" data-kid=\"27\"></i>\n          </button>\n        </div>\n        \n        \n        <div class=\"absolute -right-40 top-1/2 -translate-y-1/2 opacity-[0.03] pointer-events-none rotate-90 lg:rotate-0\" data-kid=\"28\">\n          <span class=\"font-syne text-[30rem] font-black uppercase\" data-kid=\"29\">EDITORIAL</span>\n        </div>\n      </div>\n\n      \n      <div class=\"col-span-12 lg:col-span-5 h-[500px] lg:h-[800px] bg-black overflow-hidden relative group border-t-2 lg:border-t-0 border-black\" data-kid=\"30\">\n        <img src=\"https://images.unsplash.com/photo-1765334666990-1bf2ce733864?auto=format&w=1200&q=80&fit=crop\" alt=\"Lumos Edition Editorial Model\" class=\"w-full h-full object-cover grayscale contrast-125 brightness-75 group-hover:scale-105 transition-transform duration-[2000ms]\" decoding=\"async\" loading=\"lazy\" data-kid=\"31\">\n        <div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent\" data-kid=\"32\"></div>\n        <div class=\"absolute bottom-8 right-8 text-white text-right\" data-kid=\"33\">\n          <p class=\"text-[10px] uppercase font-bold tracking-[0.3em]\" data-kid=\"34\">Campaign 01 // Neo-Luminescence</p>\n          <p class=\"font-syne text-sm italic\" data-kid=\"35\">Photography by Aris Thomsen</p>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  \n  <nav class=\"sticky top-0 z-50 border-b-2 border-black flex items-stretch h-16 sm:h-20 overflow-hidden bg-white\" data-kid=\"36\">\n    <div class=\"flex-none flex border-r-2 border-black bg-black text-white px-6 s