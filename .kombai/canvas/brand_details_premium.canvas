filled\" data-kid=\"180\"></i><i class=\"ti ti-star-filled\" data-kid=\"181\"></i><i class=\"ti ti-star-filled\" data-kid=\"182\"></i><i class=\"ti ti-star-filled\" data-kid=\"183\"></i>\n              </div>\n              <span class=\"text-[10px] text-[var(--eggplant)]/40 font-bold uppercase tracking-widest mt-0.5\" data-kid=\"184\">(2.1k Reviews)</span>\n            </div>\n            <div class=\"flex items-baseline gap-3 mb-4\" data-kid=\"185\">\n              <span class=\"text-3xl lg:text-4xl font-bold text-[var(--eggplant)]\" data-kid=\"186\">₹5,100</span>\n            </div>\n          </div>\n          <button class=\"w-full py-5 bg-[var(--eggplant)] text-white rounded-full font-bold text-base tracking-widest uppercase hover:bg-[var(--heather)] transition-all stout-shadow\" data-kid=\"187\">\n            Add to Ritual\n          </button>\n        </div>\n      </article>\n    </div>\n\n    \n    <nav class=\"flex justify-center items-center gap-4 mt-24\" data-kid=\"188\">\n      <button class=\"w-14 h-14 rounded-full border-2 border-[var(--lilac-gray)] flex items-center justify-center text-[var(--eggplant)] hover:bg-[var(--lilac-gray)] transition-all disabled:opacity-30\" data-kid=\"189\">\n        <i class=\"ti ti-chevron-left text-xl\" data-kid=\"190\"></i>\n      </button>\n      <div class=\"flex items-center gap-2 bg-white p-2 rounded-full stout-shadow border border-[var(--lilac-gray)]\" data-kid=\"191\">\n        <button class=\"w-10 h-10 rounded-full bg-[var(--eggplant)] text-white font-bold\" data-kid=\"192\">1</button>\n        <button class=\"w-10 h-10 rounded-full hover:bg-[var(--lilac-gray)] text-[var(--eggplant)] font-bold transition-all\" data-kid=\"193\">2</button>\n        <button class=\"w-10 h-10 rounded-full hover:bg-[var(--lilac-gray)] text-[var(--eggplant)] font-bold transition-all\" data-kid=\"194\">3</button>\n        <span class=\"px-2 text-[var(--eggplant)]/30 font-bold\" data-kid=\"195\">...</span>\n        <button class=\"w-10