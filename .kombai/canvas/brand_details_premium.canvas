3\"></i>\n                </button>\n                <div class=\"flex gap-4\" data-kid=\"214\">\n                    <span class=\"w-12 h-12 flex items-center justify-center bg-[#1A0B2E] text-white rounded-full font-bold text-xs\" data-kid=\"215\">01</span>\n                    <span class=\"w-12 h-12 flex items-center justify-center opacity-40 hover:opacity-100 transition-opacity cursor-pointer font-bold text-xs\" data-kid=\"216\">02</span>\n                    <span class=\"w-12 h-12 flex items-center justify-center opacity-40 hover:opacity-100 transition-opacity cursor-pointer font-bold text-xs\" data-kid=\"217\">03</span>\n                </div>\n                <button class=\"w-16 h-16 rounded-full border border-[#F3E8FF] flex items-center justify-center hover:opacity-100 transition-opacity hover:border-[#1A0B2E]\" data-kid=\"218\">\n                    <i class=\"ti ti-arrow-right text-[#1A0B2E]\" data-kid=\"219\"></i>\n                </button>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-[#FAFAFF] py-24 px-12 border-t border-[#F3E8FF]\" data-kid=\"220\">\n        <div class=\"container mx-auto grid grid-cols-4 gap-20\" data-kid=\"221\">\n            <div class=\"col-span-1\" data-kid=\"222\">\n                <h4 class=\"font-serif text-3xl mb-8\" data-kid=\"223\">Refulgent Luxury</h4>\n                <p class=\"text-sm font-light opacity-60 leading-relaxed mb-8\" data-kid=\"224\">\n                    Elevating skincare to an art form. Our commitment to refulgent beauty is absolute.\n                </p>\n                <div class=\"flex gap-6\" data-kid=\"225\">\n                    <a href=\"#\" class=\"opacity-40 hover:opacity-100\" data-kid=\"226\"><i class=\"ti ti-brand-instagram text-2xl\" data-kid=\"227\"></i></a>\n                    <a href=\"#\" class=\"opacity-40 hover:opacity-100\" data-kid=\"228\"><i class=\"ti ti-brand-pinterest text-2xl\" data-kid=\"229\"></i></a>\n                    <a href=\"#\" class=\"opacity-40 hover:opacity-100\" data-kid=\"230\"><i class=\"ti ti-brand-youtube text-2xl\" data-kid=\"231\"></i></a>\n                </div>\n            </div>\n            <div data-kid=\"232\">\n                <h5 class=\"text-[10px] tracking-[0.4em] uppercase font-bold opacity-40 mb-8\" data-kid=\"233\">Collection</h5>\n                <ul class=\"flex flex-col gap-4 text-xs font-semibold\" data-kid=\"234\">\n                    <li data-kid=\"235\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"236\">New Arrivals</a></li>\n                    <li data-kid=\"237\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"238\">Bestsellers</a></li>\n                    <li data-kid=\"239\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"240\">Summer Curation</a></li>\n                    <li data-kid=\"241\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"242\">Gift Sets</a></li>\n                </ul>\n            </div>\n            <div data-kid=\"243\">\n                <h5 class=\"text-[10px] tracking-[0.4em] uppercase font-bold opacity-40 mb-8\" data-kid=\"244\">Service</h5>\n                <ul class=\"flex flex-col gap-4 text-xs font-semibold\" data-kid=\"245\">\n                    <li data-kid=\"246\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"247\">Shipping</a></li>\n                    <li data-kid=\"248\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"249\">Returns</a></li>\n                    <li data-kid=\"250\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"251\">Radiance Loyalty</a></li>\n                    <li data-kid=\"252\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"253\">Contact</a></li>\n                </ul>\n            </div>\n            <div data-kid=\"254\">\n                <h5 class=\"text-[10px] tracking-[0.4em] uppercase font-bold opacity-40 mb-8\" data-kid=\"255\">Radiance Report</h5>\n                <p class=\"text-xs opacity-60 mb-6\" data-kid=\"256\">Subscribe for ethereal insights and exclusive curations.</p>\n                <div class=\"relative\" data-kid=\"257\">\n                    <input type=\"email\" placeholder=\"Email Address\" class=\"w-full bg-transparent border-b border-[#1A0B2E]/20 py-3 text-xs outline-none focus:border-[#9D4EDD] transition-colors\" data-kid=\"258\">\n                    <button class=\"absolute right-0 bottom-3 text-[10px] tracking-widest uppercase font-bold text-[#9D4EDD]\" data-kid=\"259\">Join</button>\n                </div>\n            </div>\n        </div>\n        <div class=\"container mx-auto mt-24 pt-10 border-t border-[#F3E8FF] flex justify-between items-center text-[9px] tracking-[0.3em] uppercase font-bold opacity-60\" data-kid=\"260\">\n            <span data-kid=\"261\">© 2024 Refulgent Luxury Collective</span>\n            <div class=\"flex gap-10\" data-kid=\"262\">\n                <a href=\"#\" class=\"hover:text-[#9D4EDD]\" data-kid=\"263\">Privacy Policy</a>\n                <a href=\"#\" class=\"hover:text-[#9D4EDD]\" data-kid=\"264\">Terms of Use</a>\n                <a href=\"#\" class=\"hover:text-[#9D4EDD]\" data-kid=\"265\">Accessibility</a>\n            </div>\n        </div>\n    </footer>\n</div>\n",
