      "html": "\n<div class=\"brand-details-container bg-white text-[#1A0B2E] font-['Montserrat']\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@200;300;400;500;600;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        :root {\n            --color-bg: #FFFFFF;\n            --color-text: #1A0B2E;\n            --color-accent: #9D4EDD;\n            --color-border: #F3E8FF;\n            --color-surface: #FAFAFF;\n            --font-serif: 'Playfair Display', serif;\n            --font-sans: 'Montserrat', sans-serif;\n            --shadow-premium: 40px 40px 80px rgba(26, 11, 46, 0.08);\n        }\n\n        .font-serif { font-family: var(--font-serif); }\n        .font-sans { font-family: var(--font-sans); }\n        .tracking-ultra { letter-spacing: 0.5em; }\n        .tracking-widest { letter-spacing: 0.2em; }\n        .tracking-mega { letter-spacing: 1.5em; }\n\n        .signature-shadow {\n            box-shadow: var(--shadow-premium);\n        }\n\n        .drop-cap {\n            font-family: var(--font-serif);\n            font-size: 8rem;\n            color: var(--color-accent);\n            float: left;\n            line-height: 0.7;\n            margin-top: 0.5rem;\n            margin-right: 1.5rem;\n            font-weight: 400;\n        }\n\n        /* Custom scroll behavior simulation for layout feel */\n        .section-label {\n            font-size: 10px;\n            font-weight: 700;\n            opacity: 0.4;\n            letter-spacing: 0.4em;\n            text-transform: uppercase;\n        }\n    </style>\n\n    \n    <nav class=\"px-12 py-8 flex justify-between items-center border-b border-[#F3E8FF] bg-white sticky top-0 z-[100]\" data-kid=\"2\">\n        <div class=\"section-label\" data-kid=\"3\">Refulgent / 2024</div>\n        <div class=\"text-xl font-serif tracking-widest font-bold\" data-kid=\"4\">REFULGENT LUXURY</div>\n        <div class=\"flex gap-8 text-[10px] tracking-widest uppercase font-bold\" data-kid=\"5\">\n            <a href=\"#\" class=\"opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"6\">Archive</a>\n            <a href=\"#\" class=\"opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"7\">Philosophy</a>\n            <a href=\"#\" class=\"text-[#9D4EDD]\" data-kid=\"8\">About</a>\n            <a href=\"#\" class=\"opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"9\">Shop</a>\n        </div>\n    </nav>\n\n    \n    <section class=\"relative min-h-[900px] flex items-center overflow-hidden\" data-kid=\"10\">\n        \n        <div class=\"absolute left-6 top-1/2 -translate-y-1/2 -rotate-90 origin-left tracking-mega font-bold opacity-20 text-[10px] whitespace-nowrap z-20\" data-kid=\"11\">\n            EST. 2012 • PARIS\n        </div>\n        \n        <div class=\"container mx-auto px-12 relative flex\" data-kid=\"12\">\n            \n            <div class=\"w-7/12 flex flex-col justify-center pl-16 relative\" data-kid=\"13\">\n                 <div class=\"absolute -top-40 -left-20 w-[600px] h-[600px] bg-[#9D4EDD]/10 rounded-full blur-[140px] pointer-events-none\" data-kid=\"14\"></div>\n                 \n                 <div class=\"mb-12 z-10\" data-kid=\"15\">\n                    <span class=\"section-label\" data-kid=\"16\">01 / BRAND ORIGIN</span>\n                 </div>\n\n                 <h1 class=\"font-serif text-[180px] leading-[0.85] tracking-tighter text-[#1A0B2E] z-10 flex flex-col mb-16\" data-kid=\"17\">\n                    <span class=\"block\" data-kid=\"18\">THE</span>\n                    <span class=\"block ml-24\" data-kid=\"19\">ORIGIN</span>\n                 </h1>\n                 \n                 <div class=\"max-w-md z-10 border-l border-[#F3E8FF] pl-8 py-4\" data-kid=\"20\">\n                    <p class=\"text-2xl font-light leading-relaxed text-[#1A0B2E]/70 italic\" data-kid=\"21\">\n                        A molecular journey into the heart of botanical luxury.\n                    </p>\n                    <p class=\"mt-8 text-base font-light opacity-50 leading-relaxed\" data-kid=\"22\">\n                        Refulgent Luxury is a standard of beauty that is as sustainable as it is sophisticated, ensuring a glowing future for both your skin and the planet.\n                    </p>\n                 </div>\n            </div>\n\n            \n            <div class=\"w-5/12 flex items-center justify-end relative pt-24\" data-kid=\"23\">\n                <div class=\"relative w-full max-w-[520px] aspect-[52/74] signature-shadow group overflow-hidden\" data-kid=\"24\">\n                    <img src=\"https://images.pexels.com/photos/7814941/pexels-photo-7814941.jpeg?auto=compress&cs=tinysrgb&w=1200&q=80\" alt=\"Minimalist cosmetic bottle on marble\" class=\"w-full h-full object-cover grayscale transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-105\" decoding=\"async\" loading=\"lazy\" data-kid=\"25\">\n                    <div class=\"absolute inset-0 bg-[#1A0B2E]/5 group-hover:bg-transparent transition-colors duration-1000\" data-kid=\"26\"></div>\n                </div>\n                \n                <div class=\"absolute -bottom-20 -left-20 w-80 h-80 bg-[#F3E8FF] rounded-full blur-[100px] -z-10 opacity-60\" data-kid=\"27\"></div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"bg-white py-40 border-y border-[#F3E8FF]\" data-kid=\"28\">\n        <div class=\"container mx-auto max-w-5xl px-12\" data-kid=\"29\">\n            <div class=\"mb-32\" data-kid=\"30\">\n                <h2 class=\"font-serif italic text-6xl text-center text-[#1A0B2E] leading-tight max-w-4xl mx-auto\" data-kid=\"31\">\n                    \"Radiance is a molecular state of harmony between nature and science.\"\n                </h2>\n            </div>\n            \n            <div class=\"relative flex gap-24 pt-12\" data-kid=\"32\">\n                \n                <div class=\"absolute left-1/2 top-0 bottom-0 w-px bg-[#F3E8FF] -translate-x-1/2 flex flex-col items-center\" data-kid=\"33\">\n                    <div class=\"w-px h-1/3 bg-[#F3E8FF]\" data-kid=\"34\"></div>\n                    <div class=\"w-16 h-16 bg-white border border-[#F3E8FF] flex items-center justify-center my-10\" data-kid=\"35\">\n                        <i class=\"ti ti-sparkles text-2xl opacity-30 text-[#9D4EDD]\" data-kid=\"36\"></i>\n                    </div>\n                    <div class=\"w-px h-1/3 bg-[#F3E8FF]\" data-kid=\"37\"></div>\n                </div>\n\n                <div class=\"w-1/2 pr-12 text-right\" data-kid=\"38\">\n                    <span class=\"section-label block mb-8\" data-kid=\"39\">Our Vision</span>\n                    <p class=\"text-xl font-light leading-[1.9] opacity-80\" data-kid=\"40\">\n                        <span class=\"drop-cap\" data-kid=\"41\">R</span>\n                        efulgent Essence was born in a small apothecary in the heart of Paris, driven by a singular vision: to create skincare that radiates from the deepest layers of the epidermis. Our founders believed that luxury shouldn't come at the cost of clinical integrity.\n                    </p>\n                </div>\n                \n                <div class=\"w-1/2 pl-12 pt-16\" data-kid=\"42\">\n                    <span class=\"section-label block mb-8\" data-kid=\"43\">Our Mission</span>\n                    <p class=\"text-xl font-light leading-[1.9] opacity-80 italic mb-10\" data-kid=\"44\">\n                        Today, our laboratories continue this legacy, blending rare botanicals with patented molecular delivery systems.\n                    </p>\n                    <p class=\"text-lg font-light leading-relaxed opacity-60\" data-kid=\"45\">\n                        We bridge the gap between pure botanical extracts and advanced molecular science, delivering results that are as visible as they are sustainable. Every formula is a testament to our commitment to clinical excellence.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"bg-[#FAFAFF] py-40 overflow-hidden\" data-kid=\"46\">\n        <div class=\"container mx-auto max-w-7xl flex items-center px-12 h-[850px]\" data-kid=\"47\">\n            \n            <div class=\"w-5/12 pr-24 relative\" data-kid=\"48\">\n                <div class=\"absolute -top-32 -left-32 w-80 h-80 bg-[#9D4EDD]/5 rounded-full blur-[100px] pointer-events-none\" data-kid=\"49\"></div>\n                <span class=\"section-label block mb-6\" data-kid=\"50\">03 / THE MINDS</span>\n                <h2 class=\"font-serif text-7xl mb-10 leading-[1.1]\" data-kid=\"51\">The Visionaries Behind The Glow</h2>\n                <p class=\"text-xl font-light opacity-60 leading-relaxed mb-12\" data-kid=\"52\">\n                    United by a shared passion for science and aesthetic harmony, our founders redefined luxury skincare through rigorous clinical research and an unwavering eye for beauty.\n                </p>\n                <div class=\"flex gap-4\" data-kid=\"53\">\n                    <div class=\"w-12 h-px bg-[#1A0B2E] mt-4 opacity-20\" data-kid=\"54\"></div>\n                    <p class=\"text-sm font-light italic opacity-50\" data-kid=\"55\">Paris • Laboratory 01</p>\n                </div>\n            </div>\n\n            \n            <div class=\"w-7/12 relative h-full\" data-kid=\"56\">\n                \n                <div class=\"absolute left-10 top-[10%] w-[420px] z-10 group\" data-kid=\"57\">\n                    <div class=\"bg-white p-6 pb-24 signature-shadow transition-transform duration-700 group-hover:-translate-y-4\" data-kid=\"58\">\n                        <div class=\"overflow-hidden mb-8\" data-kid=\"59\">\n                            <img src=\"https://images.unsplash.com/photo-1741604047914-5805eb7ff554?auto=format&w=800&q=80&fit=crop\" alt=\"Founder Elara Vance\" class=\"w-full aspect-[4/5] object-cover grayscale\" decoding=\"async\" loading=\"lazy\" data-kid=\"60\">\n                        </div>\n                        <div class=\"text-center\" data-kid=\"61\">\n                            <h4 class=\"font-serif text-4xl mb-2\" data-kid=\"62\">Elara Vance</h4>\n                            <span class=\"text-[10px] tracking-[0.4em] font-bold opacity-40 uppercase\" data-kid=\"63\">CO-FOUNDER / CHEMIST</span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"absolute right-0 bottom-[10%] w-[420px] z-20 group\" data-kid=\"64\">\n                     <div class=\"bg-white p-6 pb-24 signature-shadow transition-transform duration-700 group-hover:-translate-y-4\" data-kid=\"65\">\n                        <div class=\"overflow-hidden mb-8\" data-kid=\"66\">\n                            <img src=\"https://images.unsplash.com/photo-1646498263677-236cf46e841f?auto=format&w=800&q=80&fit=crop\" alt=\"Founder Sienna Marlo\" class=\"w-full aspect-[4/5] object-cover grayscale\" decoding=\"async\" loading=\"lazy\" data-kid=\"67\">\n                        </div>\n                        <div class=\"text-center\" data-kid=\"68\">\n                            <h4 class=\"font-serif text-4xl mb-2\" data-kid=\"69\">Sienna Marlo</h4>\n                            <span class=\"text-[10px] tracking-[0.4em] font-bold opacity-40 uppercase\" data-kid=\"70\">CO-FOUNDER / CREATIVE</span>\n                        </div>\n                    </div>\n                </div>\n                \n                \n                <div class=\"absolute -right-12 top-1/2 -translate-y-1/2 rotate-90 text-[100px] font-serif italic opacity-5 font-bold\" data-kid=\"71\">\n                    03\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"bg-white py-48 px-12\" data-kid=\"72\">\n        <div class=\"container mx-auto max-w-7xl\" data-kid=\"73\">\n            <div class=\"relative bg-[#FAFAFF] p-24 border border-[#F3E8FF] rounded-none signature-shadow overflow-visible\" data-kid=\"74\">\n                \n                \n                <div class=\"absolute -top-24 -right-16 w-80 h-80 rounded-full border-[15px] border-white shadow-[0_40px_100px_rgba(26,11,46,0.2)] overflow-hidden z-30 group\" data-kid=\"75\">\n                    <video src=\"https://videos.pexels.com/video-files/31130641/13301118_640_360_50fps.mp4\" poster=\"https://images.pexels.com/videos/31130641/waterwaves-31130641.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110\" data-kid=\"76\"></video>\n                    <div class=\"absolute inset-0 bg-[#9D4EDD]/10 mix-blend-overlay\" data-kid=\"77\"></div>\n                </div>\n\n                <div class=\"mb-20 max-w-2xl\" data-kid=\"78\">\n                    <span class=\"section-label block mb-6\" data-kid=\"79\">Our Commitment</span>\n                    <h2 class=\"font-serif text-7xl text-[#1A0B2E] mb-10 leading-tight\" data-kid=\"80\">Ethics In Every Molecule</h2>\n                    <p class=\"text-xl font-light opacity-60 leading-relaxed\" data-kid=\"81\">\n                        Sustainability is not a feature; it is our foundation. From the first drop to the final package, we ensure that our impact on the world is as gentle as our impact on your skin.\n                    </p>\n                </div>\n\n                \n                <div class=\"grid grid-cols-3 gap-20\" data-kid=\"82\">\n                    \n                    <div class=\"flex flex-col\" data-kid=\"83\">\n                        <div class=\"w-16 h-16 mb-8 flex items-center justify-center bg-white rounded-full shadow-sm\" data-kid=\"84\">\n                            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/leafy-green.svg\" class=\"w-10 h-10\" alt=\"Clean Ingredients\" data-kid=\"85\">\n                        </div>\n                        <h4 class=\"text-[11px] tracking-[0.4em] font-bold text-[#9D4EDD] uppercase mb-4\" data-kid=\"86\">Clean Ingredients</h4>\n                        <p class=\"text-sm font-light opacity-60 leading-relaxed\" data-kid=\"87\">\n                            Formulated without parabens, sulfates, or synthetic fragrances. We source only the purest botanical extracts that pass our rigorous purity standards.\n                        </p>\n                    </div>\n\n                    \n                    <div class=\"flex flex-col\" data-kid=\"88\">\n                        <div class=\"w-16 h-16 mb-8 flex items-center justify-center bg-white rounded-full shadow-sm\" data-kid=\"89\">\n                            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/recycling-symbol.svg\" class=\"w-10 h-10\" alt=\"Zero Waste\" data-kid=\"90\">\n                        </div>\n                        <h4 class=\"text-[11px] tracking-[0.4em] font-bold text-[#9D4EDD] uppercase mb-4\" data-kid=\"91\">Zero Waste</h4>\n                        <p class=\"text-sm font-light opacity-60 leading-relaxed\" data-kid=\"92\">\n                            Our packaging is designed for a circular economy. 100% recyclable glass and biodegradable secondary materials are standard in our collection.\n                        </p>\n                    </div>\n\n                    \n                    <div class=\"flex flex-col\" data-kid=\"93\">\n                        <div class=\"w-16 h-16 mb-8 flex items-center justify-center bg-white rounded-full shadow-sm\" data-kid=\"94\">\n                            <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/rabbit.svg\" class=\"w-10 h-10\" alt=\"Cruelty-Free\" data-kid=\"95\">\n                        </div>\n                        <h4 class=\"text-[11px] tracking-[0.4em] font-bold text-[#9D4EDD] uppercase mb-4\" data-kid=\"96\">Cruelty-Free</h4>\n                        <p class=\"text-sm font-light opacity-60 leading-relaxed\" data-kid=\"97\">\n                            Leaping Bunny certified. We strictly prohibit animal testing at every stage of development, ensuring beauty without compromise.\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-[#FAFAFF] py-32 px-12 border-t border-[#F3E8FF]\" data-kid=\"98\">\n        <div class=\"container mx-auto max-w-7xl\" data-kid=\"99\">\n            <div class=\"grid grid-cols-4 gap-24 mb-32\" data-kid=\"100\">\n                <div class=\"col-span-1\" data-kid=\"101\">\n                    <h4 class=\"font-serif text-3xl mb-10 tracking-widest font-bold\" data-kid=\"102\">Refulgent Luxury</h4>\n                    <p class=\"text-sm font-light opacity-60 leading-[1.8] mb-12\" data-kid=\"103\">\n                        Elevating skincare to an art form through the harmonious union of botanical wisdom and molecular science.\n                    </p>\n                    <div class=\"flex gap-8\" data-kid=\"104\">\n                        <a href=\"#\" class=\"opacity-40 hover:opacity-100 transition-opacity hover:text-[#9D4EDD]\" data-kid=\"105\"><i class=\"ti ti-brand-instagram text-2xl\" data-kid=\"106\"></i></a>\n                        <a href=\"#\" class=\"opacity-40 hover:opacity-100 transition-opacity hover:text-[#9D4EDD]\" data-kid=\"107\"><i class=\"ti ti-brand-pinterest text-2xl\" data-kid=\"108\"></i></a>\n                        <a href=\"#\" class=\"opacity-40 hover:opacity-100 transition-opacity hover:text-[#9D4EDD]\" data-kid=\"109\"><i class=\"ti ti-brand-youtube text-2xl\" data-kid=\"110\"></i></a>\n                    </div>\n                </div>\n                \n                <div data-kid=\"111\">\n                    <h5 class=\"section-label mb-10\" data-kid=\"112\">Collection</h5>\n                    <ul class=\"flex flex-col gap-5 text-[11px] tracking-widest font-bold uppercase\" data-kid=\"113\">\n                        <li data-kid=\"114\"><a href=\"#\" class=\"opacity-60 hover:opacity-100 hover:text-[#9D4EDD] transition-all\" data-kid=\"115\">New Arrivals</a></li>\n                        <li data-kid=\"116\"><a href=\"#\" class=\"opacity-60 hover:opacity-100 hover:text-[#9D4EDD] transition-all\" data-kid=\"117\">Bestsellers</a></li>\n                        <li data-kid=\"118\"><a href=\"#\" class=\"opacity-60 hover:opacity-100 hover:text-[#9D4EDD] transition-all\" data-kid=\"119\">Summer Edit</a></li>\n                        <li data-kid=\"120\"><a href=\"#\" class=\"opacity-60 hover:opacity-100 hover:text-[#9D4EDD] transition-all\" data-kid=\"121\">Gift Sets</a></li>\n                    </ul>\n                </div>\n                \n                <div data-kid=\"122\">\n                    <h5 class=\"section-label mb-10\" data-kid=\"123\">House Of Refulgence</h5>\n                    <ul class=\"flex flex-col gap-5 text-[11px] tracking-widest font-bold uppercase\" data-kid=\"124\">\n                        <li data-kid=\"125\"><a href=\"#\" class=\"opacity-60 hover:opacity-100 hover:text-[#9D4EDD] transition-all\" data-kid=\"126\">About Us</a></li>\n                        <li data-kid=\"127\"><a href=\"#\" class=\"opacity-60 hover:opacity-100 hover:text-[#9D4EDD] transition-all\" data-kid=\"128\">Sustainability</a></li>\n                        <li data-kid=\"129\"><a href=\"#\" class=\"opacity-60 hover:opacity-100 hover:text-[#9D4EDD] transition-all\" data-kid=\"130\">Philosophy</a></li>\n                        <li data-kid=\"131\"><a href=\"#\" class=\"opacity-60 hover:opacity-100 hover:text-[#9D4EDD] transition-all\" data-kid=\"132\">Contact</a></li>\n                    </ul>\n                </div>\n                \n                <div data-kid=\"133\">\n                    <h5 class=\"section-label mb-10\" data-kid=\"134\">Radiance Report</h5>\n                    <p class=\"text-xs opacity-60 mb-10 leading-relaxed\" data-kid=\"135\">Subscribe for ethereal insights and exclusive curations from our Parisian laboratory.</p>\n                    <div class=\"relative group\" data-kid=\"136\">\n                        <input type=\"email\" placeholder=\"Email Address\" class=\"w-full bg-transparent border-b border-[#1A0B2E]/20 py-4 text-xs outline-none focus:border-[#9D4EDD] transition-colors pr-16 font-medium\" data-kid=\"137\">\n                        <button class=\"absolute right-0 bottom-4 text-[10px] tracking-widest uppercase font-bold text-[#9D4EDD] hover:opacity-80 transition-opacity\" data-kid=\"138\">Join</button>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"pt-10 border-t border-[#F3E8FF] flex justify-between items-center text-[9px] tracking-[0.4em] uppercase font-bold opacity-40\" data-kid=\"139\">\n                <span data-kid=\"140\">© 2024 Refulgent Luxury Collective • Established in Paris</span>\n                <div class=\"flex gap-12\" data-kid=\"141\">\n                    <a href=\"#\" class=\"hover:opacity-100 hover:text-[#9D4EDD] transition-all\" data-kid=\"142\">Privacy Policy</a>\n                    <a href=\"#\" class=\"hover:opacity-100 hover:text-[#9D4EDD] transition-all\" data-kid=\"143\">Terms of Use</a>\n                    <a href=\"#\" class=\"hover:opacity-100 hover:text-[#9D4EDD] transition-all\" data-kid=\"144\">Accessibility</a>\n                </div>\n            </div>\n        </div>\n    </footer>\n</div>\n",
