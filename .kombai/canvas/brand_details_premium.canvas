      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,700;1,400&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --alabaster: #FBFBF9;\n    --eggplant: #3B1F4A;\n    --heather: #B892FF;\n    --lilac-gray: #EFEAF4;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--alabaster);\n    color: var(--eggplant);\n    font-family: 'Nunito', sans-serif;\n  }\n\n  .font-serif {\n    font-family: 'Lora', serif;\n  }\n\n  .stout-shadow {\n    box-shadow: 0 20px 40px -10px rgba(59, 31, 74, 0.1);\n  }\n\n  .plush-shadow {\n    box-shadow: 0 30px 60px -15px rgba(184, 146, 255, 0.3);\n  }\n\n  /* Custom wave shape for hero bottom */\n  .hero-wave {\n    position: absolute;\n    bottom: -1px;\n    left: 0;\n    width: 100%;\n    height: 120px;\n    fill: var(--alabaster);\n    z-index: 5;\n  }\n\n  /* Segmented control animation simulation */\n  .tab-active-bg {\n    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  /* Circular image rotating decor */\n  .circular-floating {\n    animation: float 6s ease-in-out infinite;\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0) rotate(var(--rot)); }\n    50% { transform: translateY(-20px) rotate(var(--rot)); }\n  }\n</style>\n\n<div class=\"bg-[var(--alabaster)] overflow-x-hidden\" data-kid=\"1\">\n  \n  \n  <header class=\"relative bg-[var(--lilac-gray)] h-[850px] flex flex-col items-center justify-center overflow-hidden\" data-kid=\"2\">\n    \n    <div class=\"absolute inset-0 opacity-40\" data-kid=\"3\">\n      <div class=\"absolute -top-24 -left-24 w-[600px] h-[600px] bg-[var(--heather)]/20 blur-[120px] rounded-full\" data-kid=\"4\"></div>\n      <div class=\"absolute top-1/2 -right-48 w-[800px] h-[800px] bg-[var(--heather)]/10 blur-[150px] rounded-full\" data-kid=\"5\"></div>\n    </div>\n\n    \n    <div class=\"absolute top-1/2 left-[10%] -translate-y-1/2 z-10 circular-floating hidden lg:block\" style=\"--rot: -8deg;\" data-kid=\"6\">\n      <div class=\"w-64 h-64 rounded-full border-8 border-white shadow-2xl overflow-hidden\" data-kid=\"7\">\n        <img src=\"https://images.unsplash.com/photo-1626285890705-06ca976a37e8?auto=format&w=500&q=80&fit=crop\" alt=\"Serum drop\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"8\">\n      </div>\n    </div>\n    <div class=\"absolute top-1/2 right-[10%] -translate-y-1/2 z-10 circular-floating hidden lg:block\" style=\"--rot: 12deg;\" data-kid=\"9\">\n      <div class=\"w-64 h-64 rounded-full border-8 border-white shadow-2xl overflow-hidden\" data-kid=\"10\">\n        <img src=\"https://images.unsplash.com/photo-1589219123229-03469f0bc3ea?auto=format&w=500&q=80&fit=crop\" alt=\"Lavender\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"11\">\n      </div>\n    </div>\n\n    \n    <div class=\"relative z-20 flex flex-col items-center px-6\" data-kid=\"12\">\n      <button class=\"mb-10 flex items-center gap-2 px-6 py-3 bg-white/80 backdrop-blur-md rounded-full text-sm font-bold border border-white hover:bg-white transition-all\" data-kid=\"13\">\n        <i class=\"ti ti-arrow-left\" data-kid=\"14\"></i> All Brands\n      </button>\n\n      <div class=\"bg-white/95 backdrop-blur-xl p-16 md:p-20 rounded-[120px] stout-shadow border-4 border-white flex flex-col items-center text-center max-w-4xl relative\" data-kid=\"15\">\n        \n        <div class=\"absolute -top-6 left-1/2 -translate-x-1/2 w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-md\" data-kid=\"16\">\n          <i class=\"ti ti-sparkles text-[var(--heather)]\" data-kid=\"17\"></i>\n        </div>\n\n        <div class=\"w-24 h-24 bg-[var(--lilac-gray)] rounded-full mb-8 flex items-center justify-center overflow-hidden border-4 border-[var(--heather)]/10\" data-kid=\"18\">\n          <span class=\"font-serif text-4xl text-[var(--heather)]\" data-kid=\"19\">W</span>\n        </div>\n        \n        <div class=\"flex items-center gap-3 text-[var(--heather)] font-bold uppercase tracking-[0.3em] text-xs mb-6\" data-kid=\"20\">\n          <span class=\"w-6 h-[1px] bg-[var(--heather)]\" data-kid=\"21\"></span>\n          Premium Wellness Est. 1994\n          <span class=\"w-6 h-[1px] bg-[var(--heather)]\" data-kid=\"22\"></span>\n        </div>\n\n        <h1 class=\"font-serif text-6xl md:text-8xl text-[var(--eggplant)] mb-6 leading-[0.9]\" data-kid=\"23\">Wellness Clinic</h1>\n        <p class=\"text-xl md:text-2xl text-[var(--eggplant)]/60 font-serif italic max-w-2xl leading-relaxed\" data-kid=\"24\">\n          The art of gentle restoration, where botanical purity meets clinical precision to nurture your skin's natural intelligence.\n        </p>\n\n        <div class=\"mt-10 flex flex-wrap justify-center gap-4\" data-kid=\"25\">\n          <span class=\"px-6 py-3 bg-[var(--lilac-gray)] rounded-full text-sm font-bold text-[var(--eggplant)] flex items-center gap-2\" data-kid=\"26\">\n            🌍 France\n          </span>\n          <span class=\"px-6 py-3 bg-[var(--lilac-gray)] rounded-full text-sm font-bold text-[var(--eggplant)] flex items-center gap-2\" data-kid=\"27\">\n            Est. 1994\n          </span>\n          <span class=\"px-6 py-3 bg-[var(--lilac-gray)] rounded-full text-sm font-bold text-[var(--eggplant)] flex items-center gap-2\" data-kid=\"28\">\n            🐰 Cruelty-Free\n          </span>\n        </div>\n      </div>\n    </div>\n\n    \n    <svg class=\"hero-wave\" viewBox=\"0 0 1440 120\" preserveAspectRatio=\"none\" data-kid=\"29\">\n      <path d=\"M0,120 L1440,120 L1440,0 C1200,80 720,120 0,0 L0,120 Z\" data-kid=\"30\"></path>\n    </svg>\n  </header>\n\n  \n  <section class=\"max-w-7xl mx-auto -mt-10 relative z-30 px-6\" data-kid=\"31\">\n    <div class=\"bg-white p-3 rounded-[50px] stout-shadow border border-[var(--lilac-gray)] flex flex-wrap items-center justify-between\" data-kid=\"32\">\n      \n      <nav class=\"flex p-1 bg-[var(--lilac-gray)] rounded-full\" data-kid=\"33\">\n        <button class=\"px-8 py-4 rounded-full font-bold text-[var(--eggplant)] bg-[var(--heather)] shadow-lg transition-all\" data-kid=\"34\">All Products</button>\n        <button class=\"px-8 py-4 rounded-full font-bold text-[var(--eggplant)]/50 hover:text-[var(--eggplant)] transition-all\" data-kid=\"35\">Skincare</button>\n        <button class=\"px-8 py-4 rounded-full font-bold text-[var(--eggplant)]/50 hover:text-[var(--eggplant)] transition-all\" data-kid=\"36\">Serum</button>\n        <button class=\"px-8 py-4 rounded-full font-bold text-[var(--eggplant)]/50 hover:text-[var(--eggplant)] transition-all\" data-kid=\"37\">Wellness</button>\n      </nav>\n\n      \n      <div class=\"flex items-center gap-4 px-6 mt-4 lg:mt-0\" data-kid=\"38\">\n        <span class=\"text-sm font-bold text-[var(--eggplant)]/40 uppercase tracking-widest\" data-kid=\"39\">Sort by</span>\n        <div class=\"relative\" data-kid=\"40\">\n          <select class=\"appearance-none bg-[var(--lilac-gray)] border-none rounded-full px-8 py-4 pr-12 font-bold text-[var(--eggplant)] focus:ring-2 focus:ring-[var(--heather)] cursor-pointer\" data-kid=\"41\">\n            <option data-kid=\"42\">Featured</option>\n            <option data-kid=\"43\">Newest</option>\n            <option data-kid=\"44\">Rating</option>\n          </select>\n          <i class=\"ti ti-chevron-down absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none\" data-kid=\"45\"></i>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"max-w-7xl mx-auto py-32 px-6\" data-kid=\"46\">\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch\" data-kid=\"47\">\n      \n      <div class=\"bg-white p-12 md:p-16 rounded-[40px] stout-shadow border border-[var(--lilac-gray)] flex flex-col justify-center\" data-kid=\"48\">\n        <div class=\"inline-block w-12 h-1 bg-[var(--heather)] mb-8\" data-kid=\"49\"></div>\n        <h2 class=\"font-serif text-4xl md:text-5xl text-[var(--eggplant)] mb-8 leading-tight\" data-kid=\"50\">Our Nurturing Narrative</h2>\n        <p class=\"text-lg md:text-xl text-[var(--eggplant)]/80 leading-relaxed\" data-kid=\"51\">\n          Founded in 1994, Wellness Clinic emerged from a vision to treat the skin not as a surface to be corrected, but as a living ecosystem to be nurtured. Our formulations prioritize biomimetic ingredients that synchronize with your body's natural rhythms.\n        </p>\n      </div>\n      <div class=\"rounded-[40px] overflow-hidden stout-shadow min-h-[500px] border border-[var(--lilac-gray)]\" data-kid=\"52\">\n        <video src=\"https://videos.pexels.com/video-files/4132712/4132712-sd_960_540_25fps.mp4\" poster=\"https://images.pexels.com/videos/4132712/olej-cbd-4132712.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover\" preload=\"metadata\" data-kid=\"53\"></video>\n      </div>\n\n      \n      <div class=\"bg-[var(--lilac-gray)] p-12 md:p-16 rounded-[40px] flex flex-col items-center justify-center text-center border border-[var(--heather)]/10\" data-kid=\"54\">\n        <div class=\"grid grid-cols-3 gap-8 md:gap-12 mb-10\" data-kid=\"55\">\n          <div class=\"flex flex-col items-center gap-4\" data-kid=\"56\">\n            <div class=\"w-16 h-16 md:w-20 md:h-20 bg-white rounded-full flex items-center justify-center shadow-sm hover:scale-110 transition-transform\" data-kid=\"57\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/mono/herb.svg\" class=\"w-8 h-8 md:w-10 md:h-10\" style=\"color: var(--eggplant);\" alt=\"Herb\" data-kid=\"58\">\n            </div>\n            <span class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--eggplant)]/50\" data-kid=\"59\">Botanical</span>\n          </div>\n          <div class=\"flex flex-col items-center gap-4\" data-kid=\"60\">\n            <div class=\"w-16 h-16 md:w-20 md:h-20 bg-white rounded-full flex items-center justify-center shadow-sm hover:scale-110 transition-transform\" data-kid=\"61\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/mono/element.svg\" class=\"w-8 h-8 md:w-10 md:h-10\" style=\"color: var(--eggplant);\" alt=\"Element\" data-kid=\"62\">\n            </div>\n            <span class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--eggplant)]/50\" data-kid=\"63\">Clinical</span>\n          </div>\n          <div class=\"flex flex-col items-center gap-4\" data-kid=\"64\">\n            <div class=\"w-16 h-16 md:w-20 md:h-20 bg-white rounded-full flex items-center justify-center shadow-sm hover:scale-110 transition-transform\" data-kid=\"65\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/mono/leafy-green.svg\" class=\"w-8 h-8 md:w-10 md:h-10\" style=\"color: var(--eggplant);\" alt=\"Leaf\" data-kid=\"66\">\n            </div>\n            <span class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--eggplant)]/50\" data-kid=\"67\">Organic</span>\n          </div>\n        </div>\n        <p class=\"font-serif text-2xl text-[var(--eggplant)] max-w-sm italic leading-relaxed\" data-kid=\"68\">\n          \"Wellness is the perfect harmony between science and soul.\"\n        </p>\n      </div>\n      <div class=\"rounded-[40px] overflow-hidden stout-shadow min-h-[500px] border border-[var(--lilac-gray)]\" data-kid=\"69\">\n        <img src=\"https://images.unsplash.com/photo-1591443372837-614191fc95e5?auto=format&w=800&q=80&fit=crop\" alt=\"Lavender fields\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"70\">\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"max-w-7xl mx-auto px-6 pb-32\" data-kid=\"71\">\n    <div class=\"relative bg-white rounded-[60px] p-12 md:p-20 overflow-hidden border-8 border-[var(--lilac-gray)] plush-shadow\" data-kid=\"72\">\n      \n      <div class=\"absolute inset-0 bg-gradient-to-br from-[var(--lilac-gray)]/50 to-transparent\" data-kid=\"73\"></div>\n      <div class=\"absolute -top-32 -right-32 w-96 h-96 bg-[var(--heather)]/30 blur-[100px] rounded-full\" data-kid=\"74\"></div>\n      \n      <div class=\"relative z-10 flex flex-col lg:flex-row items-center justify-between gap-16\" data-kid=\"75\">\n        <div class=\"max-w-2xl text-center lg:text-left\" data-kid=\"76\">\n          <div class=\"flex items-center justify-center lg:justify-start gap-3 mb-8\" data-kid=\"77\">\n            <span class=\"w-12 h-[2px] bg-[var(--eggplant)]\" data-kid=\"78\"></span>\n            <span class=\"text-xs font-bold uppercase tracking-[0.4em] text-[var(--eggplant)]\" data-kid=\"79\">Limited Time Opportunity</span>\n          </div>\n          <h2 class=\"font-serif text-6xl md:text-7xl text-[var(--eggplant)] mb-8 leading-[1.1]\" data-kid=\"80\">The Summer<br data-kid=\"81\">Serenity Edit</h2>\n          <p class=\"text-xl md:text-2xl text-[var(--eggplant)]/60 mb-12 font-serif italic max-w-lg leading-relaxed\" data-kid=\"82\">\n            Invite tranquility into your daily ritual. Discover curated essentials for luminous, rested skin.\n          </p>\n          <button class=\"group px-14 py-6 bg-[var(--eggplant)] text-white rounded-full font-bold text-lg hover:bg-[var(--heather)] transition-all flex items-center gap-4 mx-auto lg:mx-0\" data-kid=\"83\">\n            Explore the Collection\n            <i class=\"ti ti-arrow-right group-hover:translate-x-2 transition-transform\" data-kid=\"84\"></i>\n          </button>\n        </div>\n        \n        <div class=\"shrink-0 relative group\" data-kid=\"85\">\n          <div class=\"absolute inset-0 bg-[var(--heather)]/20 blur-[40px] rounded-full scale-110 opacity-30 group-hover:opacity-100 transition-opacity\" data-kid=\"86\"></div>\n          <div class=\"w-64 h-64 md:w-80 md:h-80 rounded-full bg-white stout-shadow border-[16px] border-[var(--lilac-gray)] flex flex-col items-center justify-center text-[var(--eggplant)] relative\" data-kid=\"87\">\n            <span class=\"text-7xl md:text-8xl font-serif\" data-kid=\"88\">40<span class=\"text-4xl ml-1\" data-kid=\"89\">%</span></span>\n            <span class=\"text-xs font-bold uppercase tracking-[0.3em] mt-4 opacity-50\" data-kid=\"90\">Exclusive Savings</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <main class=\"max-w-7xl mx-auto px-6 pb-40\" data-kid=\"91\">\n    <div class=\"flex items-center justify-between mb-16\" data-kid=\"92\">\n      <h2 class=\"font-serif text-5xl text-[var(--eggplant)]\" data-kid=\"93\">Discover the Clinic</h2>\n      <div class=\"text-[var(--eggplant)]/40 font-bold uppercase tracking-widest text-sm\" data-kid=\"94\">\n        Showing <span class=\"text-[var(--eggplant)]\" data-kid=\"95\">12</span> of 48 products\n      </div>\n    </div>\n\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12\" data-kid=\"96\">\n      \n      <article class=\"flex flex-col sm:flex-row bg-white rounded-[40px] overflow-hidden stout-shadow border border-[var(--lilac-gray)] group hover:-translate-y-2 transition-all duration-500 h-auto sm:h-[480px]\" data-kid=\"97\">\n        <div class=\"w-full sm:w-[45%] bg-[var(--lilac-gray)] relative overflow-hidden flex items-center justify-center p-4 lg:p-6\" data-kid=\"98\">\n          <img src=\"https://images.unsplash.com/photo-1679394270597-e90694d70350?auto=format&w=800&q=80&fit=crop\" alt=\"Lavender Serum\" class=\"w-full h-full object-contain mix-blend-multiply scale-110 group-hover:scale-125 transition-transform duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"99\">\n          <div class=\"absolute top-6 left-6 px-4 py-1.5 bg-[var(--eggplant)] text-white text-[10px] font-bold uppercase tracking-widest rounded-full z-10\" data-kid=\"100\">Bestseller</div>\n          <button class=\"absolute top-6 right-6 w-11 h-11 bg-white rounded-full flex items-center justify-center text-[var(--heather)] shadow-lg hover:bg-[var(--heather)] hover:text-white transition-all z-10\" data-kid=\"101\">\n            <i class=\"ti ti-heart text-xl\" data-kid=\"102\"></i>\n          </button>\n        </div>\n        <div class=\"w-full sm:w-[55%] p-8 lg:p-12 flex flex-col justify-between bg-white\" data-kid=\"103\">\n          <div data-kid=\"104\">\n            <div class=\"flex items-center gap-2 mb-4\" data-kid=\"105\">\n              <span class=\"w-4 h-[1px] bg-[var(--heather)]\" data-kid=\"106\"></span>\n              <span class=\"text-[10px] font-bold text-[var(--heather)] uppercase tracking-[0.2em]\" data-kid=\"107\">Skincare Ritual</span>\n            </div>\n            <h3 class=\"font-serif text-3xl lg:text-4xl text-[var(--eggplant)] mb-4 leading-tight\" data-kid=\"108\">Lavender Restoration Serum</h3>\n            <div class=\"flex items-center gap-3 mb-8\" data-kid=\"109\">\n              <div class=\"flex text-[#9D72FF] text-sm\" data-kid=\"110\">\n                <i class=\"ti ti-star-filled\" data-kid=\"111\"></i><i class=\"ti ti-star-filled\" data-kid=\"112\"></i><i class=\"ti ti-star-filled\" data-kid=\"113\"></i><i class=\"ti ti-star-filled\" data-kid=\"114\"></i><i class=\"ti ti-star-half-filled\" data-kid=\"115\"></i>\n              </div>\n              <span class=\"text-[10px] text-[var(--eggplant)]/40 font-bold uppercase tracking-widest mt-0.5\" data-kid=\"116\">(1.2k Reviews)</span>\n            </div>\n            <div class=\"flex items-baseline gap-3 mb-4\" data-kid=\"117\">\n              <span class=\"text-3xl lg:text-4xl font-bold text-[var(--eggplant)]\" data-kid=\"118\">₹3,450</span>\n              <span class=\"text-lg text-[var(--eggplant)]/20 line-through\" data-kid=\"119\">₹4,200</span>\n            </div>\n          </div>\n          <button class=\"w-full py-5 bg-[var(--eggplant)] text-white rounded-full font-bold text-base tracking-widest uppercase hover:bg-[var(--heather)] transition-all stout-shadow\" data-kid=\"120\">\n            Add to Ritual\n          </button>\n        </div>\n      </article>\n\n      \n      <article class=\"flex flex-col sm:flex-row bg-white rounded-[40px] overflow-hidden stout-shadow border border-[var(--lilac-gray)] group hover:-translate-y-2 transition-all duration-500 h-auto sm:h-[480px]\" data-kid=\"121\">\n        <div class=\"w-full sm:w-[45%] bg-[var(--lilac-gray)] relative overflow-hidden flex items-center justify-center p-4 lg:p-6\" data-kid=\"122\">\n          <img src=\"https://images.unsplash.com/photo-1672062519629-abe610383152?auto=format&w=800&q=80&fit=crop\" alt=\"Oil\" class=\"w-full h-full object-contain mix-blend-multiply scale-110 group-hover:scale-125 transition-transform duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"123\">\n          <div class=\"absolute top-6 left-6 px-4 py-1.5 bg-[var(--heather)] text-[var(--eggplant)] text-[10px] font-bold uppercase tracking-widest rounded-full z-10\" data-kid=\"124\">New Era</div>\n          <button class=\"absolute top-6 right-6 w-11 h-11 bg-white rounded-full flex items-center justify-center text-[var(--heather)] shadow-lg hover:bg-[var(--heather)] hover:text-white transition-all z-10\" data-kid=\"125\">\n            <i class=\"ti ti-heart text-xl\" data-kid=\"126\"></i>\n          </button>\n        </div>\n        <div class=\"w-full sm:w-[55%] p-8 lg:p-12 flex flex-col justify-between bg-white\" data-kid=\"127\">\n          <div data-kid=\"128\">\n            <div class=\"flex items-center gap-2 mb-4\" data-kid=\"129\">\n              <span class=\"w-4 h-[1px] bg-[var(--heather)]\" data-kid=\"130\"></span>\n              <span class=\"text-[10px] font-bold text-[var(--heather)] uppercase tracking-[0.2em]\" data-kid=\"131\">Wellness Extract</span>\n            </div>\n            <h3 class=\"font-serif text-3xl lg:text-4xl text-[var(--eggplant)] mb-4 leading-tight\" data-kid=\"132\">Midnight Recovery Botanical Oil</h3>\n            <div class=\"flex items-center gap-3 mb-8\" data-kid=\"133\">\n              <div class=\"flex text-[#9D72FF] text-sm\" data-kid=\"134\">\n                <i class=\"ti ti-star-filled\" data-kid=\"135\"></i><i class=\"ti ti-star-filled\" data-kid=\"136\"></i><i class=\"ti ti-star-filled\" data-kid=\"137\"></i><i class=\"ti ti-star-filled\" data-kid=\"138\"></i><i class=\"ti ti-star-filled\" data-kid=\"139\"></i>\n              </div>\n              <span class=\"text-[10px] text-[var(--eggplant)]/40 font-bold uppercase tracking-widest mt-0.5\" data-kid=\"140\">(850 Reviews)</span>\n            </div>\n            <div class=\"flex items-baseline gap-3 mb-4\" data-kid=\"141\">\n              <span class=\"text-3xl lg:text-4xl font-bold text-[var(--eggplant)]\" data-kid=\"142\">₹2,800</span>\n            </div>\n          </div>\n          <button class=\"w-full py-5 bg-[var(--eggplant)] text-white rounded-full font-bold text-base tracking-widest uppercase hover:bg-[var(--heather)] transition-all stout-shadow\" data-kid=\"143\">\n            Add to Ritual\n          </button>\n        </div>\n      </article>\n\n      \n      <article class=\"flex flex-col sm:flex-row bg-white rounded-[40px] overflow-hidden stout-shadow border border-[var(--lilac-gray)] group hover:-translate-y-2 transition-all duration-500 h-auto sm:h-[480px]\" data-kid=\"144\">\n        <div class=\"w-full sm:w-[45%] bg-[var(--lilac-gray)] relative overflow-hidden flex items-center justify-center p-4 lg:p-6\" data-kid=\"145\">\n          <img src=\"https://images.unsplash.com/photo-1567765865603-cb729e7cd5a6?auto=format&w=800&q=80&fit=crop\" alt=\"Serum\" class=\"w-full h-full object-contain mix-blend-multiply scale-110 group-hover:scale-125 transition-transform duration-700\" decoding=\"async\" loading=\"