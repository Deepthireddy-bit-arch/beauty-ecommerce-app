      "html": "\n<div class=\"brand-details-container bg-white text-[#1A0B2E] font-['Montserrat'] overflow-x-hidden\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@200;300;400;500;600;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        :root {\n            --color-bg: #FFFFFF;\n            --color-text: #1A0B2E;\n            --color-accent: #9D4EDD;\n            --color-border: #F3E8FF;\n            --color-surface: #FAFAFF;\n            --font-serif: 'Playfair Display', serif;\n            --font-sans: 'Montserrat', sans-serif;\n            --shadow-premium: 40px 40px 80px rgba(26, 11, 46, 0.08);\n            --transition-smooth: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .font-serif { font-family: var(--font-serif); }\n        .font-sans { font-family: var(--font-sans); }\n        .tracking-ultra { letter-spacing: 0.5em; }\n\n        .sale-video-bubble {\n            border-radius: 50%;\n            border: 12px solid #1A0B2E;\n            box-shadow: 0 30px 60px rgba(0,0,0,0.3);\n            overflow: hidden;\n            background: #1A0B2E;\n        }\n\n        /* Watermark utility */\n        .watermark-text {\n            font-family: var(--font-serif);\n            font-size: 20vw;\n            font-weight: 700;\n            color: var(--color-accent);\n            opacity: 0.05;\n            white-space: nowrap;\n            pointer-events: none;\n            user-select: none;\n            line-height: 1;\n            letter-spacing: -0.05em;\n        }\n\n        /* Animations */\n        @keyframes subtle-float {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-15px); }\n        }\n        .animate-float { animation: subtle-float 6s ease-in-out infinite; }\n    </style>\n\n    \n    <nav class=\"px-12 py-8 flex justify-between items-center border-b border-[#F3E8FF] bg-white relative z-50\" data-kid=\"2\">\n        <div class=\"text-[10px] tracking-[0.4em] uppercase font-bold opacity-60\" data-kid=\"3\">About / Narrative</div>\n        <div class=\"text-xl font-serif tracking-widest font-bold\" data-kid=\"4\">REFULGENT LUXURY</div>\n        <div class=\"flex gap-8 text-[10px] tracking-widest uppercase font-bold\" data-kid=\"5\">\n            <a href=\"#\" class=\"opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"6\">Archive</a>\n            <a href=\"#\" class=\"opacity-60 hover:opacity-100 transition-opacity\" data-kid=\"7\">Sustainability</a>\n            <a href=\"#\" class=\"text-[#9D4EDD]\" data-kid=\"8\">Shop</a>\n        </div>\n    </nav>\n\n    \n    <section class=\"relative h-[850px] flex items-center justify-center overflow-hidden bg-white\" data-kid=\"9\">\n        \n        <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"10\">\n            <h2 class=\"watermark-text\" data-kid=\"11\">REFULGENT</h2>\n        </div>\n\n        <div class=\"relative z-10 flex flex-col items-center text-center max-w-3xl px-6\" data-kid=\"12\">\n            \n            <div class=\"mb-14 relative group\" data-kid=\"13\">\n                <div class=\"w-64 h-64 rounded-full overflow-hidden border border-[#F3E8FF] shadow-2xl relative z-10\" data-kid=\"14\">\n                     <video src=\"https://videos.pexels.com/video-files/19265262/19265262-uhd_2560_1440_24fps.mp4\" poster=\"https://images.pexels.com/videos/19265262/pexels-photo-19265262.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover grayscale-[0.2] group-hover:grayscale-0 transition-all duration-1000\" data-kid=\"15\">\n                     </video>\n                </div>\n                \n                <div class=\"absolute inset-0 -z-10 bg-[#9D4EDD] opacity-10 blur-[120px] scale-[2] pointer-events-none\" data-kid=\"16\"></div>\n                <div class=\"absolute -top-6 -right-6 w-12 h-12 bg-white rounded-full flex items-center justify-center border border-[#F3E8FF] animate-float shadow-sm\" data-kid=\"17\">\n                    <i class=\"ti ti-sparkles text-[#9D4EDD]\" data-kid=\"18\"></i>\n                </div>\n            </div>\n\n            <h1 class=\"font-serif italic text-7xl md:text-8xl mb-10 leading-[0.9] tracking-tight text-[#1A0B2E]\" data-kid=\"19\">\n                Our Ethereal <br data-kid=\"20\"> Narrative\n            </h1>\n            \n            <p class=\"text-sm font-light leading-[1.8] tracking-wider opacity-60 max-w-lg\" data-kid=\"21\">\n                At Refulgent, we believe beauty is a molecular state of harmony. Our narrative began with a single drop of essence and a vision to illuminate the skin from within. A standard of luxury that is as scientific as it is ethereal.\n            </p>\n\n            <div class=\"mt-16 flex flex-col items-center\" data-kid=\"22\">\n                 <div class=\"w-px h-24 bg-gradient-to-b from-[#9D4EDD] to-transparent mb-4\" data-kid=\"23\"></div>\n                 <span class=\"text-[9px] font-bold tracking-[0.5em] uppercase opacity-40\" data-kid=\"24\">The Legacy of Light</span>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"bg-white\" data-kid=\"25\">\n        \n        <div class=\"flex flex-row h-[700px] border-y border-[#F3E8FF]\" data-kid=\"26\">\n            \n            <div class=\"w-1/2 flex items-center justify-center p-20 bg-[#FAFAFF] relative\" data-kid=\"27\">\n                <div class=\"border border-[#F3E8FF] p-16 max-w-lg bg-white relative z-10 shadow-sm transition-transform duration-700 hover:-translate-y-2\" data-kid=\"28\">\n                    <span class=\"text-[10px] font-bold tracking-[0.4em] text-[#9D4EDD] mb-8 block uppercase\" data-kid=\"29\">01 / Our Mission</span>\n                    <h2 class=\"font-serif text-5xl mb-8 leading-tight\" data-kid=\"30\">Molecular <br data-kid=\"31\"> Equilibrium</h2>\n                    <p class=\"text-sm font-light leading-relaxed opacity-70\" data-kid=\"32\">\n                        To redefine the architecture of skincare by bridging the gap between botanical purity and clinical excellence. We strive to create formulas that don't just mimic health, but foster a biological environment where radiance is the natural state of existence.\n                    </p>\n                </div>\n                \n                <div class=\"absolute left-10 top-1/2 -translate-y-1/2 text-8xl font-serif text-[#1A0B2E]/5 select-none\" data-kid=\"33\">M</div>\n            </div>\n            \n            <div class=\"w-1/2 relative overflow-hidden\" data-kid=\"34\">\n                <img src=\"https://images.unsplash.com/photo-1710580889701-9fa8f2cd5927?auto=format&w=1200&q=80&fit=crop\" alt=\"Macro Skin Texture\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"35\">\n                \n                <div class=\"absolute bottom-[-15rem] left-[-15rem] w-[35rem] h-[35rem] bg-[#F3E8FF] rounded-full blur-[100px] opacity-40 mix-blend-multiply\" data-kid=\"36\"></div>\n                <div class=\"absolute inset-0 bg-gradient-to-t from-[#1A0B2E]/10 to-transparent\" data-kid=\"37\"></div>\n            </div>\n        </div>\n\n        \n        <div class=\"flex flex-row h-[700px] border-b border-[#F3E8FF]\" data-kid=\"38\">\n            \n            <div class=\"w-1/2 relative overflow-hidden\" data-kid=\"39\">\n                <img src=\"https://images.unsplash.com/photo-1682875392533-0b6812b2fa4a?auto=format&w=1200&q=80&fit=crop\" alt=\"Abstract Purple Silk\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"40\">\n                \n                <div class=\"absolute top-[-15rem] right-[-15rem] w-[35rem] h-[35rem] bg-[#9D4EDD]/5 rounded-full blur-[100px] opacity-30\" data-kid=\"41\"></div>\n                <div class=\"absolute inset-0 bg-gradient-to-b from-[#1A0B2E]/10 to-transparent\" data-kid=\"42\"></div>\n            </div>\n            \n            <div class=\"w-1/2 flex items-center justify-center p-20 bg-[#FAFAFF] relative\" data-kid=\"43\">\n                <div class=\"border border-[#F3E8FF] p-16 max-w-lg bg-white relative z-10 shadow-sm transition-transform duration-700 hover:-translate-y-2\" data-kid=\"44\">\n                    <span class=\"text-[10px] font-bold tracking-[0.4em] text-[#9D4EDD] mb-8 block uppercase\" data-kid=\"45\">02 / Our Vision</span>\n                    <h2 class=\"font-serif text-5xl mb-8 leading-tight\" data-kid=\"46\">Conscious <br data-kid=\"47\"> Brilliance</h2>\n                    <p class=\"text-sm font-light leading-relaxed opacity-70\" data-kid=\"48\">\n                        Envisioning a future where the glow of the skin is matched by the health of the earth. We are pioneering a new era of \"sustainable refulgence\"—where high-end luxury serves as a catalyst for environmental restoration and ethical consumption.\n                    </p>\n                </div>\n                \n                <div class=\"absolute right-10 top-1/2 -translate-y-1/2 text-8xl font-serif text-[#1A0B2E]/5 select-none\" data-kid=\"49\">V</div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"bg-[#1A0B2E] text-white py-32 relative overflow-hidden\" data-kid=\"50\">\n        \n        <div class=\"absolute -top-40 -left-40 w-[600px] h-[600px] bg-[#9D4EDD]/10 rounded-full blur-[150px] pointer-events-none\" data-kid=\"51\"></div>\n        <div class=\"absolute -bottom-40 -right-40 w-[500px] h-[500px] bg-[#F3E8FF]/5 rounded-full blur-[120px] pointer-events-none\" data-kid=\"52\"></div>\n\n        <div class=\"container mx-auto px-12 relative z-10\" data-kid=\"53\">\n            <div class=\"grid lg:grid-cols-12 gap-20 items-center\" data-kid=\"54\">\n                <div class=\"lg:col-span-5\" data-kid=\"55\">\n                    <span class=\"text-xs font-bold tracking-[0.5em] text-[#9D4EDD] mb-8 block uppercase\" data-kid=\"56\">The Architects</span>\n                    <h2 class=\"font-serif text-7xl md:text-8xl mb-12 leading-[0.9]\" data-kid=\"57\">Meet the<br data-kid=\"58\">Founders</h2>\n                    <p class=\"text-lg font-light leading-relaxed opacity-50 max-w-md mb-12\" data-kid=\"59\">\n                        Bound by a shared pursuit of aesthetic transcendence and scientific rigor, Elena and Marcus founded Refulgent to bridge the divide between laboratory precision and artistic soul.\n                    </p>\n                    <div class=\"flex gap-12 border-t border-white/10 pt-12\" data-kid=\"60\">\n                         <div class=\"flex flex-col\" data-kid=\"61\">\n                            <span class=\"text-[9px] tracking-widest uppercase opacity-40 mb-2\" data-kid=\"62\">Heritage</span>\n                            <span class=\"text-sm font-semibold tracking-wide\" data-kid=\"63\">Parisian Roots</span>\n                         </div>\n                         <div class=\"flex flex-col\" data-kid=\"64\">\n                            <span class=\"text-[9px] tracking-widest uppercase opacity-40 mb-2\" data-kid=\"65\">Philosophy</span>\n                            <span class=\"text-sm font-semibold tracking-wide\" data-kid=\"66\">Molecular Art</span>\n                         </div>\n                    </div>\n                </div>\n\n                <div class=\"lg:col-span-7 relative h-[700px]\" data-kid=\"67\">\n                    \n                    <div class=\"absolute top-0 right-0 w-72 h-72 sale-video-bubble z-20 group cursor-pointer\" data-kid=\"68\">\n                        <img src=\"https://images.unsplash.com/photo-1506863530036-1efeddceb993?auto=format&w=600&q=80&fit=crop\" alt=\"Elena Vance\" class=\"w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0\" data-kid=\"69\">\n                        <div class=\"absolute inset-0 bg-[#1A0B2E]/20 group-hover:bg-transparent transition-colors\" data-kid=\"70\"></div>\n                    </div>\n                    \n                    <div class=\"absolute top-80 right-0 text-right\" data-kid=\"71\">\n                        <span class=\"font-serif italic text-3xl block mb-1\" data-kid=\"72\">Elena Vance</span>\n                        <span class=\"text-[9px] tracking-widest opacity-40 uppercase\" data-kid=\"73\">Chief Creative Officer</span>\n                    </div>\n\n                    \n                    <div class=\"absolute bottom-10 left-10 w-80 h-80 sale-video-bubble z-10 group cursor-pointer\" data-kid=\"74\">\n                        <img src=\"https://images.unsplash.com/photo-1720345174544-65637a5307bf?auto=format&w=600&q=80&fit=crop\" alt=\"Dr. Marcus Thorne\" class=\"w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0\" data-kid=\"75\">\n                        <div class=\"absolute inset-0 bg-[#1A0B2E]/20 group-hover:bg-transparent transition-colors\" data-kid=\"76\"></div>\n                    </div>\n                    \n                    <div class=\"absolute bottom-0 left-24\" data-kid=\"77\">\n                        <span class=\"font-serif italic text-3xl block mb-1\" data-kid=\"78\">Dr. Marcus Thorne</span>\n                        <span class=\"text-[9px] tracking-widest opacity-40 uppercase\" data-kid=\"79\">Director of Formulation</span>\n                    </div>\n\n                    \n                    <svg class=\"absolute inset-0 w-full h-full pointer-events-none opacity-10\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" data-kid=\"80\">\n                        <path d=\"M70,30 Q50,50 30,70\" stroke=\"white\" stroke-width=\"0.1\" fill=\"none\" data-kid=\"81\"></path>\n                    </svg>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"bg-white py-32 px-12\" data-kid=\"82\">\n        <div class=\"container mx-auto max-w-7xl\" data-kid=\"83\">\n            <div class=\"grid lg:grid-cols-12 gap-24\" data-kid=\"84\">\n                \n                <div class=\"lg:col-span-5\" data-kid=\"85\">\n                    <span class=\"text-[10px] font-bold tracking-[0.5em] text-[#9D4EDD] mb-8 block uppercase\" data-kid=\"86\">Ethical Manifesto</span>\n                    <h2 class=\"font-serif text-6xl leading-tight mb-12\" data-kid=\"87\">Sustainability <br data-kid=\"88\"> in Every Drop</h2>\n                    <p class=\"text-sm font-light opacity-60 leading-relaxed max-w-sm\" data-kid=\"89\">\n                        Our commitment to ethics is woven into the very molecular structure of our brand. We operate with radical transparency and uncompromising standards.\n                    </p>\n                    <div class=\"mt-16 flex items-center gap-6\" data-kid=\"90\">\n                        <div class=\"w-16 h-16 rounded-full border border-[#F3E8FF] flex items-center justify-center\" data-kid=\"91\">\n                            <i class=\"ti ti-leaf text-[#9D4EDD]\" data-kid=\"92\"></i>\n                        </div>\n                        <span class=\"text-[11px] font-bold tracking-widest opacity-40 uppercase\" data-kid=\"93\">100% Vegan & Cruelty-Free</span>\n                    </div>\n                </div>\n\n                \n                <div class=\"lg:col-span-7\" data-kid=\"94\">\n                    <div class=\"group py-14 border-t border-[#F3E8FF] flex items-center justify-between transition-all duration-700 hover:bg-[#FAFAFF] hover:px-8\" data-kid=\"95\">\n                        <div class=\"flex items-center gap-16\" data-kid=\"96\">\n                            <span class=\"text-[11px] font-bold tracking-ultra opacity-30 group-hover:opacity-100 group-hover:text-[#9D4EDD] transition-all\" data-kid=\"97\">01</span>\n                            <h3 class=\"font-serif text-4xl tracking-wide uppercase group-hover:italic group-hover:translate-x-6 transition-all duration-700\" data-kid=\"98\">Ethical Sourcing</h3>\n                        </div>\n                        <div class=\"w-12 h-12 rounded-full border border-[#F3E8FF] flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all\" data-kid=\"99\">\n                            <i class=\"ti ti-arrow-right text-[#9D4EDD]\" data-kid=\"100\"></i>\n                        </div>\n                    </div>\n\n                    <div class=\"group py-14 border-t border-[#F3E8FF] flex items-center justify-between transition-all duration-700 hover:bg-[#FAFAFF] hover:px-8\" data-kid=\"101\">\n                        <div class=\"flex items-center gap-16\" data-kid=\"102\">\n                            <span class=\"text-[11px] font-bold tracking-ultra opacity-30 group-hover:opacity-100 group-hover:text-[#9D4EDD] transition-all\" data-kid=\"103\">02</span>\n                            <h3 class=\"font-serif text-4xl tracking-wide uppercase group-hover:italic group-hover:translate-x-6 transition-all duration-700\" data-kid=\"104\">Molecular Recycling</h3>\n                        </div>\n                        <div class=\"w-12 h-12 rounded-full border border-[#F3E8FF] flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all\" data-kid=\"105\">\n                            <i class=\"ti ti-arrow-right text-[#9D4EDD]\" data-kid=\"106\"></i>\n                        </div>\n                    </div>\n\n                    <div class=\"group py-14 border-t border-b border-[#F3E8FF] flex items-center justify-between transition-all duration-700 hover:bg-[#FAFAFF] hover:px-8\" data-kid=\"107\">\n                        <div class=\"flex items-center gap-16\" data-kid=\"108\">\n                            <span class=\"text-[11px] font-bold tracking-ultra opacity-30 group-hover:opacity-100 group-hover:text-[#9D4EDD] transition-all\" data-kid=\"109\">03</span>\n                            <h3 class=\"font-serif text-4xl tracking-wide uppercase group-hover:italic group-hover:translate-x-6 transition-all duration-700\" data-kid=\"110\">Carbon Neutrality</h3>\n                        </div>\n                        <div class=\"w-12 h-12 rounded-full border border-[#F3E8FF] flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all\" data-kid=\"111\">\n                            <i class=\"ti ti-arrow-right text-[#9D4EDD]\" data-kid=\"112\"></i>\n                        </div>\n                    </div>\n\n                    <p class=\"mt-14 text-xs font-light opacity-50 text-right italic\" data-kid=\"113\">\n                        \"Transparency is the highest form of radiance.\"\n                    </p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-[#FAFAFF] py-24 px-12 border-t border-[#F3E8FF]\" data-kid=\"114\">\n        <div class=\"container mx-auto\" data-kid=\"115\">\n            <div class=\"grid lg:grid-cols-4 gap-20\" data-kid=\"116\">\n                <div class=\"col-span-1\" data-kid=\"117\">\n                    <h4 class=\"font-serif text-3xl mb-8\" data-kid=\"118\">Refulgent Luxury</h4>\n                    <p class=\"text-sm font-light opacity-60 leading-relaxed mb-8\" data-kid=\"119\">\n                        Elevating skincare to an art form. Our commitment to refulgent beauty is absolute, ensuring a future that glows for all.\n                    </p>\n                    <div class=\"flex gap-6\" data-kid=\"120\">\n                        <a href=\"#\" class=\"opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"121\"><i class=\"ti ti-brand-instagram text-2xl\" data-kid=\"122\"></i></a>\n                        <a href=\"#\" class=\"opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"123\"><i class=\"ti ti-brand-pinterest text-2xl\" data-kid=\"124\"></i></a>\n                        <a href=\"#\" class=\"opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"125\"><i class=\"ti ti-brand-youtube text-2xl\" data-kid=\"126\"></i></a>\n                    </div>\n                </div>\n                \n                <div class=\"lg:ml-auto\" data-kid=\"127\">\n                    <h5 class=\"text-[10px] tracking-[0.4em] uppercase font-bold opacity-40 mb-8\" data-kid=\"128\">Navigation</h5>\n                    <ul class=\"flex flex-col gap-4 text-xs font-semibold\" data-kid=\"129\">\n                        <li data-kid=\"130\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"131\">Our Story</a></li>\n                        <li data-kid=\"132\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"133\">Archive</a></li>\n                        <li data-kid=\"134\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"135\">Formulation</a></li>\n                        <li data-kid=\"136\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"137\">Shop All</a></li>\n                    </ul>\n                </div>\n\n                <div class=\"lg:ml-auto\" data-kid=\"138\">\n                    <h5 class=\"text-[10px] tracking-[0.4em] uppercase font-bold opacity-40 mb-8\" data-kid=\"139\">Service</h5>\n                    <ul class=\"flex flex-col gap-4 text-xs font-semibold\" data-kid=\"140\">\n                        <li data-kid=\"141\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"142\">Shipping</a></li>\n                        <li data-kid=\"143\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"144\">Returns</a></li>\n                        <li data-kid=\"145\"><a href=\"#\" class=\"hover:text-[#9D4EDD] transition-colors\" data-kid=\"146\">Loyalty</a></li>\n                        <li data-kid=\"147\"><a href=\"#\" class=\"hover:text-[#9D4ED