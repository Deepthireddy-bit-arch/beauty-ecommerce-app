utton>\n      </div>\n\n      <div class=\"flex flex-wrap justify-center gap-12 text-sm font-bold uppercase tracking-[0.2em] text-white/40\" data-kid=\"210\">\n        <a href=\"#\" class=\"hover:text-white transition-all\" data-kid=\"211\">Privacy</a>\n        <a href=\"#\" class=\"hover:text-white transition-all\" data-kid=\"212\">Sustainability</a>\n        <a href=\"#\" class=\"hover:text-white transition-all\" data-kid=\"213\">Clinics</a>\n        <a href=\"#\" class=\"hover:text-white transition-all\" data-kid=\"214\">Contact</a>\n      </div>\n      \n      <p class=\"mt-24 text-xs font-bold text-white/20 uppercase tracking-widest\" data-kid=\"215\">\n        &copy; 2024 Wellness Clinic. All rights reserved. Crafting purity since 1994.\n      </p>\n    </div>\n  </footer>\n\n</div>\n",
