      "html": "\n<body class=\"bg-boutique text-[#2D263B] font-inter\">\n    <style data-kid=\"0\">\n        @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Inter:wght@300;400;500;600&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .font-syne { font-family: 'Syne', sans-serif; }\n        .font-inter { font-family: 'Inter', sans-serif; }\n\n        .pentagon-badge {\n            clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%);\n        }\n\n        .arch-cutout {\n            border-radius: 200px 200px 0 0;\n        }\n\n        .diagonal-split {\n            clip-path: polygon(30% 0, 100% 0, 100% 100%, 15% 100%);\n        }\n\n        .bg-boutique {\n            background-color: #FDFDFD;\n            background-image: radial-gradient(#E0AAFF 0.5px, transparent 0.5px);\n            background-size: 32px 32px;\n            background-attachment: fixed;\n        }\n\n        /* Custom scrollbar for boutique feel */\n        ::-webkit-scrollbar {\n            width: 6px;\n        }\n        ::-webkit-scrollbar-track {\n            background: #FDFDFD;\n        }\n        ::-webkit-scrollbar-thumb {\n            background: #5A189A;\n        }\n    </style>\n\n    \n    <nav class=\"absolute top-8 left-12 z-50\" data-kid=\"1\">\n        <button class=\"flex items-center gap-2 group font-syne font-bold uppercase tracking-widest text-sm hover:text-[#5A189A] transition-colors\" data-kid=\"2\">\n            <i class=\"ti ti-arrow-left text-lg group-hover:-translate-x-1 transition-transform\" data-kid=\"3\"></i>\n            All Brands\n        </button>\n    </nav>\n\n    \n    <section class=\"min-h-[850px] relative overflow-hidden flex items-center px-12 pt-24 pb-12\" data-kid=\"4\">\n        \n        <div class=\"absolute top-1/2 left-[12%] -translate-y-1/2 w-[55%] h-[65%] bg-[#E0AAFF]/15 -z-10 transform -rotate-2\" data-kid=\"5\"></div>\n        \n        <div class=\"container mx-auto grid grid-cols-12 gap-12 items-center relative\" data-kid=\"6\">\n            \n            <div class=\"col-span-7 z-20\" data-kid=\"7\">\n                <div class=\"flex items-center gap-8 mb-10\" data-kid=\"8\">\n                    <div class=\"w-24 h-24 bg-[#5A189A] flex items-center justify-center pentagon-badge shadow-xl transition-transform hover:scale-110 cursor-pointer\" data-kid=\"9\">\n                        <span class=\"text-white font-syne font-extrabold text-3xl\" data-kid=\"10\">LV</span>\n                    </div>\n                    <div class=\"flex flex-col\" data-kid=\"11\">\n                        <div class=\"flex items-center gap-4\" data-kid=\"12\">\n                            <span class=\"font-inter text-[#2D263B]/60 uppercase tracking-[0.3em] text-[10px] font-bold\" data-kid=\"13\">Maison de Beauté</span>\n                            <div class=\"h-[1px] w-16 bg-[#5A189A]\" data-kid=\"14\"></div>\n                        </div>\n                        <span class=\"font-inter text-[#2D263B] font-semibold text-xs mt-1 uppercase tracking-widest\" data-kid=\"15\">Est. 1992 · Paris</span>\n                    </div>\n                </div>\n\n                <h1 class=\"font-syne text-[100px] font-extrabold text-[#2D263B] leading-[0.8] tracking-tighter mb-12\" data-kid=\"16\">\n                    LUMIÈRE<br data-kid=\"17\">\n                    <span class=\"ml-24 text-[#5A189A]\" data-kid=\"18\">VIOLETTE</span>\n                </h1>\n\n                <div class=\"ml-24 max-w-lg\" data-kid=\"19\">\n                    <p class=\"font-inter text-[#2D263B]/70 text-xl leading-relaxed mb-12\" data-kid=\"20\">\n                        A curated collection of sensory experiences, blending architectural precision with the ethereal essence of Royal Violet. Our formulas are a testament to scientific rigor and botanical poetry.\n                    </p>\n\n                    <div class=\"flex items-center gap-16 border-t border-[#E0AAFF] pt-8\" data-kid=\"21\">\n                        <div data-kid=\"22\">\n                            <div class=\"text-5xl font-syne font-bold text-[#2D263B]\" data-kid=\"23\">4.9★</div>\n                            <div class=\"text-[10px] font-inter text-[#2D263B]/50 uppercase tracking-[0.2em] mt-2\" data-kid=\"24\">Avg Rating</div>\n                        </div>\n                        <div data-kid=\"25\">\n                            <div class=\"text-5xl font-syne font-bold text-[#2D263B]\" data-kid=\"26\">124</div>\n                            <div class=\"text-[10px] font-inter text-[#2D263B]/50 uppercase tracking-[0.2em] mt-2\" data-kid=\"27\">Unique Products</div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"col-span-5 relative h-[750px] mt-12\" data-kid=\"28\">\n                \n                <div class=\"absolute top-0 right-0 w-[90%] h-[75%] overflow-hidden shadow-[40px_40px_80px_rgba(45,38,59,0.15)] z-0 transform rotate-2\" data-kid=\"29\">\n                    <img src=\"https://images.unsplash.com/photo-1742540425709-7610d1affa0a?auto=format&w=1200&q=80&fit=crop\" alt=\"Model Portrait\" class=\"w-full h-full object-cover grayscale-[0.1]\" decoding=\"async\" loading=\"lazy\" data-kid=\"30\">\n                </div>\n                \n                <div class=\"absolute bottom-4 -left-12 w-[65%] h-[50%] border-[20px] border-[#FDFDFD] shadow-[30px_30px_60px_rgba(45,38,59,0.2)] z-20 transform -rotate-3 overflow-hidden\" data-kid=\"31\">\n                    <img src=\"https://images.unsplash.com/photo-1586858248899-fa6f7a0c759a?auto=format&w=800&q=80&fit=crop\" alt=\"Signature Fragrance\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"32\">\n                </div>\n                \n                <div class=\"absolute -bottom-10 -right-10 w-48 h-48 bg-[#5A189A]/5 rounded-full blur-[100px] -z-10\" data-kid=\"33\"></div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-12 container mx-auto\" data-kid=\"34\">\n        <div class=\"grid grid-cols-12 gap-20\" data-kid=\"35\">\n            \n            <div class=\"col-span-5\" data-kid=\"36\">\n                <span class=\"font-inter text-[#5A189A] font-bold text-xs uppercase tracking-[0.3em] mb-4 block\" data-kid=\"37\">The Philosophy</span>\n                <h2 class=\"font-syne text-5xl font-extrabold text-[#2D263B] mb-8 leading-tight\" data-kid=\"38\">About Lumière Violette</h2>\n                <p class=\"font-inter text-[#2D263B]/60 text-lg leading-relaxed\" data-kid=\"39\">\n                    Founded with the vision of marrying architectural form with fluid beauty, Lumière Violette focuses on the transformative power of violet light and botanical extracts. Every product is a masterpiece of precision and sensory delight.\n                </p>\n            </div>\n            \n            <div class=\"col-span-7 grid grid-cols-3 gap-8\" data-kid=\"40\">\n                <div class=\"border-t-8 border-[#5A189A] pt-10 px-6 bg-white shadow-sm transition-all hover:shadow-lg hover:-translate-y-2 group\" data-kid=\"41\">\n                    <div class=\"mb-8 text-[#5A189A] transition-transform group-hover:scale-110\" data-kid=\"42\">\n                        <i class=\"ti ti-leaf text-5xl\" data-kid=\"43\"></i>\n                    </div>\n                    <h4 class=\"font-syne text-xs uppercase tracking-[0.3em] font-extrabold text-[#2D263B] mb-4 leading-tight\" data-kid=\"44\">Clean Ingredients</h4>\n                    <p class=\"font-inter text-[#2D263B]/50 text-xs leading-relaxed\" data-kid=\"45\">\n                        Ethically sourced botanicals paired with non-toxic synthetics for pure efficacy.\n                    </p>\n                </div>\n                <div class=\"border-t-8 border-[#5A189A] pt-10 px-6 bg-white shadow-sm transition-all hover:shadow-lg hover:-translate-y-2 group\" data-kid=\"46\">\n                    <div class=\"mb-8 text-[#5A189A] transition-transform group-hover:scale-110\" data-kid=\"47\">\n                        <i class=\"ti ti-shield-heart text-5xl\" data-kid=\"48\"></i>\n                    </div>\n                    <h4 class=\"font-syne text-xs uppercase tracking-[0.3em] font-extrabold text-[#2D263B] mb-4 leading-tight\" data-kid=\"49\">Clinically Tested</h4>\n                    <p class=\"font-inter text-[#2D263B]/50 text-xs leading-relaxed\" data-kid=\"50\">\n                        Rigorous scientific validation ensures every drop performs to professional standards.\n                    </p>\n                </div>\n                <div class=\"border-t-8 border-[#5A189A] pt-10 px-6 bg-white shadow-sm transition-all hover:shadow-lg hover:-translate-y-2 group\" data-kid=\"51\">\n                    <div class=\"mb-8 text-[#5A189A] transition-transform group-hover:scale-110\" data-kid=\"52\">\n                        <i class=\"ti ti-clover text-5xl\" data-kid=\"53\"></i>\n                    </div>\n                    <h4 class=\"font-syne text-xs uppercase tracking-[0.3em] font-extrabold text-[#2D263B] mb-4 leading-tight\" data-kid=\"54\">Sustainable</h4>\n                    <p class=\"font-inter text-[#2D263B]/50 text-xs leading-relaxed\" data-kid=\"55\">\n                        Refillable glass and carbon-neutral logistics for a beauty that lasts lifetimes.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"pt-24 pb-4 px-12 container mx-auto\" data-kid=\"56\">\n        <div class=\"flex flex-col md:flex-row justify-between items-start md:items-end border-b border-[#2D263B]/10 pb-8 gap-8\" data-kid=\"57\">\n            <div data-kid=\"58\">\n                <h2 class=\"font-syne text-6xl font-extrabold text-[#2D263B]\" data-kid=\"59\">The Collection</h2>\n                <p class=\"font-inter text-[#2D263B]/40 mt-4 tracking-widest uppercase text-xs font-bold\" data-kid=\"60\">Refine by your ritual</p>\n            </div>\n            <div class=\"flex flex-wrap gap-3 justify-end\" data-kid=\"61\">\n                <button class=\"px-6 py-2 rounded-full font-syne text-xs font-extrabold uppercase tracking-widest bg-[#5A189A] text-white shadow-lg transition-all hover:shadow-royal hover:-translate-y-1\" data-kid=\"62\">All Rituals</button>\n                <button class=\"px-6 py-2 rounded-full font-syne text-xs font-extrabold uppercase tracking-widest border border-[#E0AAFF] text-[#2D263B] hover:bg-[#E0AAFF]/10 transition-all\" data-kid=\"63\">Skincare</button>\n                <button class=\"px-6 py-2 rounded-full font-syne text-xs font-extrabold uppercase tracking-widest border border-[#E0AAFF] text-[#2D263B] hover:bg-[#E0AAFF]/10 transition-all\" data-kid=\"64\">Makeup</button>\n                <button class=\"px-6 py-2 rounded-full font-syne text-xs font-extrabold uppercase tracking-widest border border-[#E0AAFF] text-[#2D263B] hover:bg-[#E0AAFF]/10 transition-all\" data-kid=\"65\">Fragrance</button>\n                <button class=\"px-6 py-2 rounded-full font-syne text-xs font-extrabold uppercase tracking-widest border border-[#E0AAFF] text-[#2D263B] hover:bg-[#E0AAFF]/10 transition-all\" data-kid=\"66\">Haircare</button>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-12 px-12 container mx-auto\" data-kid=\"67\">\n        <div class=\"relative h-[360px] overflow-hidden group shadow-2xl\" data-kid=\"68\">\n            \n            <div class=\"absolute inset-0 bg-white\" data-kid=\"69\"></div>\n            \n            <div class=\"absolute inset-0 bg-[#5A189A] transition-all duration-700 group-hover:scale-x-105\" style=\"clip-path: polygon(60% 0, 100% 0, 100% 100%, 50% 100%);\" data-kid=\"70\"></div>\n            \n            <div class=\"relative z-10 w-full h-full flex items-center\" data-kid=\"71\">\n                \n                <div class=\"w-[50%] pl-24 flex flex-col justify-center\" data-kid=\"72\">\n                    <span class=\"font-inter text-[#5A189A] font-bold text-xs uppercase tracking-[0.4em] mb-4\" data-kid=\"73\">Summer Soirée</span>\n                    <h2 class=\"font-syne text-[64px] font-black text-[#2D263B] leading-[0.85] mb-6\" data-kid=\"74\">SEASONAL<br data-kid=\"75\">EDIT</h2>\n                    <p class=\"font-inter text-[#2D263B]/60 text-sm max-w-xs font-bold uppercase tracking-[0.2em]\" data-kid=\"76\">Limited archive access</p>\n                </div>\n                \n                <div class=\"w-[50%] ml-auto pr-24 flex flex-col items-end justify-center text-white text-right\" data-kid=\"77\">\n                    <div class=\"text-[110px] font-syne font-black leading-none mb-2 tracking-tighter\" data-kid=\"78\">40% OFF</div>\n                    <div class=\"font-inter text-white/80 text-xs tracking-[0.2em] font-bold uppercase mb-8\" data-kid=\"79\">Ends June 30 · Free Global Shipping</div>\n                    <button class=\"px-12 py-4 bg-[#FDFDFD] text-[#5A189A] font-syne font-bold uppercase tracking-[0.3em] text-xs shadow-2xl hover:bg-[#E0AAFF] hover:text-[#2D263B] transition-all hover:scale-105\" data-kid=\"80\">\n                        Shop the Sale\n                    </button>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-16 px-12 container mx-auto\" data-kid=\"81\">\n        <div class=\"grid grid-cols-12 gap-12\" data-kid=\"82\">\n            \n            <div class=\"col-span-4 mt-12\" data-kid=\"83\">\n                <article class=\"border border-[#2D263B] p-8 bg-white relative group transition-all duration-500 hover:shadow-2xl\" data-kid=\"84\">\n                    <div class=\"aspect-[3/4] overflow-hidden arch-cutout mb-8 bg-[#F8F8F8]\" data-kid=\"85\">\n                        <img src=\"https://images.unsplash.com/photo-1608721279136-cd41b752fa41?auto=format&w=800&q=80&fit=crop\" alt=\"Midnight Essence\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"86\">\n                    </div>\n                    <div class=\"space-y-4\" data-kid=\"87\">\n                        <div class=\"flex justify-between items-start\" data-kid=\"88\">\n                            <div data-kid=\"89\">\n                                <span class=\"font-inter text-[10px] uppercase tracking-[0.3em] text-[#5A189A] font-bold\" data-kid=\"90\">Fragrance</span>\n                                <h3 class=\"font-syne text-2xl font-extrabold text-[#2D263B] mt-1\" data-kid=\"91\">Midnight Amethyst</h3>\n                            </div>\n                            <button class=\"text-[#2D263B] hover:text-[#5A189A] transition-colors\" data-kid=\"92\"><i class=\"ti ti-heart text-2xl\" data-kid=\"93\"></i></button>\n                        </div>\n                        <p class=\"font-inter text-[#2D263B]/50 text-xs leading-relaxed\" data-kid=\"94\">Top notes of violet leaf and blackcurrant over a smoky base.</p>\n                        <div class=\"flex justify-between items-center pt-6 border-t border-[#2D263B]/10\" data-kid=\"95\">\n                            <span class=\"font-syne text-2xl font-bold\" data-kid=\"96\">₹4,500</span>\n                            <button class=\"w-14 h-14 bg-[#5A189A] text-white flex items-center justify-center transition-all duration-300 hover:bg-[#2D263B] hover:rotate-45\" data-kid=\"97\">\n                                <i class=\"ti ti-arrow-up-right text-2xl\" data-kid=\"98\"></i>\n                            </button>\n                        </div>\n                    </div>\n                </article>\n            </div>\n\n            \n            <div class=\"col-span-4\" data-kid=\"99\">\n                <article class=\"border border-[#2D263B] p-8 bg-white relative group transition-all duration-500 hover:shadow-2xl\" data-kid=\"100\">\n                    <div class=\"absolute -top-3 left-8 bg-[#5A189A] text-white px-4 py-1 text-[10px] font-bold uppercase tracking-[0.3em] shadow-lg z-30\" data-kid=\"101\">Bestseller</div>\n                    <div class=\"aspect-[3/4] overflow-hidden arch-cutout mb-8 bg-[#F8F8F8]\" data-kid=\"102\">\n                        <img src=\"https://images.pexels.com/photos/13875784/pexels-photo-13875784.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Violet Glow\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"103\">\n                    </div>\n                    <div class=\"space-y-4\" data-kid=\"104\">\n                        <div class=\"flex justify-between items-start\" data-kid=\"105\">\n                            <div data-kid=\"106\">\n                                <span class=\"font-inter text-[10px] uppercase tracking-[0.3em] text-[#5A189A] font-bold\" data-kid=\"107\">Skincare</span>\n                                <h3 class=\"font-syne text-2xl font-extrabold text-[#2D263B] mt-1\" data-kid=\"108\">Violet Glow Serum</h3>\n                            </div>\n                            <button class=\"text-[#5A189A]\" data-kid=\"109\"><i class=\"ti ti-heart-filled text-2xl\" data-kid=\"110\"></i></button>\n                        </div>\n                        <p class=\"font-inter text-[#2D263B]/50 text-xs leading-relaxed\" data-kid=\"111\">Infused with real amethyst dust and hyaluronic complex.</p>\n                        <div class=\"flex justify-between items-center pt-6 border-t border-[#2D263B]/10\" data-kid=\"112\">\n                            <span class=\"font-syne text-2xl font-bold\" data-kid=\"113\">₹2,850</span>\n                            <button class=\"w-14 h-14 bg-[#5A189A] text-white flex items-center justify-center transition-all duration-300 hover:bg-[#2D263B] hover:rotate-45\" data-kid=\"114\">\n                                <i class=\"ti ti-arrow-up-right text-2xl\" data-kid=\"115\"></i>\n                            </button>\n                        </div>\n                    </div>\n                </article>\n            </div>\n\n            \n            <div class=\"col-span-4 mt-16\" data-kid=\"116\">\n                <article class=\"border border-[#2D263B] p-8 bg-white relative group transition-all duration-500 hover:shadow-2xl\" data-kid=\"117\">\n                    <div class=\"aspect-[3/4] overflow-hidden arch-cutout mb-8 bg-[#F8F8F8]\" data-kid=\"118\">\n                        <img src=\"https://images.pexels.com/photos/16025659/pexels-photo-16025659.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Royal Mist\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"119\">\n                    </div>\n                    <div class=\"space-y-4\" data-kid=\"120\">\n                        <div class=\"flex justify-between items-start\" data-kid=\"121\">\n                            <div data-kid=\"122\">\n                                <span class=\"font-inter text-[10px] uppercase tracking-[0.3em] text-[#5A189A] font-bold\" data-kid=\"123\">Fragrance</span>\n                                <h3 class=\"font-syne text-2xl font-extrabold text-[#2D263B] mt-1\" data-kid=\"124\">Royal Mist Parfum</h3>\n                            </div>\n                            <button class=\"text-[#2D263B] hover:text-[#5A189A] transition-colors\" data-kid=\"125\"><i class=\"ti ti-heart text-2xl\" data-kid=\"126\"></i></button>\n                        </div>\n                        <p class=\"font-inter text-[#2D263B]/50 text-xs leading-relaxed\" data-kid=\"127\">A majestic blend of royal lavender and white musk.</p>\n                        <div class=\"flex justify-between items-center pt-6 border-t border-[#2D263B]/10\" data-kid=\"128\">\n                            <div class=\"flex items-center gap-2\" data-kid=\"129\">\n                                <span class=\"font-syne text-2xl font-bold\" data-kid=\"130\">₹6,200</span>\n                                <span class=\"text-[#2D263B]/30 line-through text-sm\" data-kid=\"131\">₹7,500</span>\n                            </div>\n                            <button class=\"w-14 h-14 bg-[#5A189A] text-white flex items-center justify-center transition-all duration-300 hover:bg-[#2D263B] hover:rotate-45\" data-kid=\"132\">\n                                <i class=\"ti ti-arrow-up-right text-2xl\" data-kid=\"133\"></i>\n                            </button>\n                        </div>\n                    </div>\n                </article>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"py-32 px-12 border-t border-[#2D263B]/10 container mx-auto text-center\" data-kid=\"134\">\n        <div class=\"w-20 h-20 bg-[#5A189A] flex items-center justify-center pentagon-badge shadow-xl mx-auto mb-12\" data-kid=\"135\">\n            <span class=\"text-white font-syne font-extrabold text-2xl\" data-kid=\"136\">LV</span>\n        </div>\n        <h2 class=\"font-syne text-3xl font-extrabold text-[#2D263B] mb-4\" data-kid=\"137\">LUMIÈRE VIOLETTE</h2>\n        <p class=\"font-inter text-[#2D263B]/40 uppercase tracking-[0.4em] text-[10px] font-bold mb-16\" data-kid=\"138\">The architectural pursuit of beauty</p>\n        \n        <div class=\"flex justify-center gap-12 mb-20\" data-kid=\"139\">\n            <a href=\"#\" class=\"font-syne font-bold uppercase tracking-widest text-xs hover:text-[#5A189A] transition-colors\" data-kid=\"140\">Privacy Rituals</a>\n            <a href=\"#\" class=\"font-syne font-bold uppercase tracking-widest text-xs hover:text-[#5A189A] transition-colors\" data-kid=\"141\">Shipping Etiquette</a>\n            <a href=\"#\" class=\"font-syne font-bold uppercase tracking-widest text-xs hover:text-[#5A189A] transition-colors\" data-kid=\"142\">Member Registry</a>\n        </div>\n        \n        <div class=\"text-[#2D263B]/50 text-[10px] font-bold uppercase tracking-[0.2em]\" data-kid=\"143\">\n            © 2024 Lumière Violette Boutique. All sensory rights reserved.\n        </div>\n    </footer>\n\n</body>\n",
